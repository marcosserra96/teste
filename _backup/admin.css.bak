}

.brand-context small {
  margin-top: 3px !important;
  font-size: .76rem !important;
  opacity: .84 !important;
  white-space: nowrap !important;
}

.topbar-actions {
  flex: 1 1 auto !important;
  display: flex !important;
  justify-content: flex-end !important;
  align-items: center !important;
  gap: 10px !important;
  min-width: 0 !important;
}

.topbar-slim .global-search {
  flex: 0 1 420px !important;
  max-width: 420px !important;
  min-width: 260px !important;
  height: 42px !important;
}

.topbar-slim .global-search input {
  height: 42px !important;
  font-size: .88rem !important;
}

.topbar-slim .btn-topo {
  width: 42px !important;
  height: 42px !important;
  min-width: 42px !important;
  border-radius: 14px !important;
}

#userGroupBadge {
  min-height: 34px !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 13px !important;
  border-radius: 12px !important;
  line-height: 1 !important;
}

/* Garante respiro no fim da página para o menu flutuante não cobrir cards */
main {
  padding-bottom: 130px !important;
}

/* Identidade visual: cards mais estáveis e sem sobreposição */
.admin-brand-card {
  overflow: visible !important;
}

.admin-brand-card .admin-panel-header {
  margin-bottom: 16px !important;
}

.admin-brand-card .brand-admin-grid {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 14px !important;
  margin: 0 0 18px 0 !important;
  align-items: stretch !important;
}

.admin-brand-card .brand-preview {
  min-height: 168px !important;
  padding: 16px !important;
  gap: 12px !important;
  justify-content: space-between !important;
  border-radius: 18px !important;
}

.admin-brand-card .brand-preview span {
  display: block !important;
  line-height: 1.1 !important;
}

.admin-brand-card .brand-preview img {
  width: 100% !important;
  max-width: 220px !important;
  height: 58px !important;
  object-fit: contain !important;
  object-position: left center !important;
}

.admin-brand-card .brand-preview small {
  display: block !important;
  max-width: 260px !important;
}

.admin-brand-card .brand-editor-layout {
  display: grid !important;
  grid-template-columns: 1fr !important;
  gap: 18px !important;
  margin-top: 0 !important;
  align-items: start !important;
}

.admin-brand-card .brand-color-editor {
  display: grid !important;
  grid-template-columns: repeat(3, minmax(150px, 1fr)) !important;
  gap: 12px !important;
  align-items: stretch !important;
  max-width: 100% !important;
}

.admin-brand-card .brand-color-editor label {
  display: grid !important;
  grid-template-columns: 1fr !important;
  grid-template-rows: auto 42px !important;
  min-height: 88px !important;
  padding: 12px !important;
  gap: 9px !important;
  align-items: start !important;
  overflow: hidden !important;
  line-height: 1.15 !important;
}

.admin-brand-card .brand-color-editor input[type="color"] {
  width: 100% !important;
  height: 42px !important;
  min-width: 0 !important;
  border-radius: 12px !important;
}

.admin-brand-card .brand-theme-preview {
  width: 100% !important;
  max-width: 760px !important;
  min-height: 0 !important;
  padding: 16px !important;
  border-radius: 20px !important;
  margin-top: 0 !important;
  justify-self: start !important;
  gap: 12px !important;
}

.admin-brand-card .brand-theme-card {
  margin-top: 0 !important;
  padding: 15px !important;
}

.admin-brand-card .brand-theme-preview code {
  display: block !important;
  margin-top: 0 !important;
  overflow-wrap: anywhere !important;
}

.admin-brand-card .brand-admin-actions {
  margin-top: 18px !important;
  display: flex !important;
  gap: 12px !important;
  align-items: center !important;
  flex-wrap: wrap !important;
}

.admin-brand-card .brand-admin-actions .btn-primario,
.admin-brand-card .brand-admin-actions .btn-acao {
  min-height: 46px !important;
  padding: 0 18px !important;
}

.admin-brand-card .brand-note-box {
  margin-top: 14px !important;
}

@media (min-width: 1180px) {
  .admin-brand-card .brand-editor-layout {
    grid-template-columns: minmax(0, 1fr) minmax(320px, 420px) !important;
    align-items: start !important;
  }
  .admin-brand-card .brand-color-editor {
    grid-template-columns: repeat(3, minmax(130px, 1fr)) !important;
  }
  .admin-brand-card .brand-theme-preview {
    max-width: none !important;
  }
}

@media (max-width: 920px) {
  .topbar.topbar-slim {
    height: auto !important;
    min-height: 64px !important;
    padding: 9px 14px !important;
  }
  .topbar-brand {
    min-width: 0 !important;
    max-width: none !important;
    flex: 1 1 auto !important;
  }
  .topbar-program-logo {
    width: 120px !important;
    height: 38px !important;
  }
  .brand-context strong {
    font-size: .92rem !important;
  }
  .brand-context small {
    font-size: .70rem !important;
  }
  .topbar-actions {
    width: 100% !important;
  }
  .topbar-slim .global-search {
    flex: 1 1 100% !important;
    max-width: none !important;
    min-width: 0 !important;
  }
  .admin-brand-card .brand-admin-grid,
  .admin-brand-card .brand-color-editor {
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  }
}

@media (max-width: 620px) {
  main {
    padding-bottom: 150px !important;
  }
  .brand-divider,
  .brand-context small {
    display: none !important;
  }
  .topbar-program-logo {
    width: 112px !important;
  }
  .admin-brand-card .brand-admin-grid,
  .admin-brand-card .brand-color-editor {
    grid-template-columns: 1fr !important;
  }
  .admin-brand-card .brand-admin-actions .btn-primario,
  .admin-brand-card .brand-admin-actions .btn-acao {
    width: 100% !important;
  }
}

/* =====================================================
   V50 — Design System, Transições e Drag & Drop Premium
   ===================================================== */
:root {
  --ease-premium: cubic-bezier(.2,.8,.2,1);
  --surface-1: rgba(255,255,255,.92);
  --surface-2: rgba(255,255,255,.76);
  --line-soft: rgba(0, 155, 193, .12);
  --shadow-soft: 0 18px 45px rgba(14, 39, 63, .08);
  --shadow-hover: 0 22px 55px rgba(14, 39, 63, .14);
  --radius-card: 24px;
  --radius-control: 14px;
}

html { scroll-behavior: smooth; }
body {
  text-rendering: geometricPrecision;
}

@media (prefers-reduced-motion: no-preference) {
  main > section,
  .sub-content,
  .t-content,
  .ficha-tab-content,
  .modal .modal-content,
  .ficha-modal-shell {
    animation: v50FadeUp .28s var(--ease-premium) both;
  }

  .card,
  .analysis-card,
  .strategic-action-card,
  .program-health-card,
  .executive-kpi,
  .admin-panel-card,
  .admin-kpi-card,
  .quick-export-panel,
  .login-box,
  .btn-primario,
  .btn-acao,
  .btn-topo,
  .t-tab,
  .sub-tab,
  .nav-item,
  .menu-flutuante button {
    transition:
      transform .20s var(--ease-premium),
      box-shadow .20s var(--ease-premium),
      border-color .20s var(--ease-premium),
      background-color .20s var(--ease-premium),
      color .20s var(--ease-premium),
      opacity .20s var(--ease-premium);
  }
}

@keyframes v50FadeUp {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Superfícies: menos aspecto de cards soltos e mais produto único */
.card,
.analysis-card,
.strategic-action-card,
.program-health-card,
.admin-panel-card,
.quick-export-panel,
.admin-control-hero,
.podium-card,
.ficha-modal-shell,
.modal-content {
  border-radius: var(--radius-card) !important;
  border: 1px solid rgba(0, 155, 193, .10) !important;
  box-shadow: var(--shadow-soft) !important;
}

.card:hover,
.analysis-card:hover,
.strategic-action-card:hover,
.admin-panel-card:hover,
.quick-export-panel:hover,
.program-health-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-hover) !important;
}

/* Títulos padronizados */
.analysis-card-header h3,
.strategic-action-card h3,
.admin-panel-header h3,
.admin-control-hero h3,
.card h3,
.header-acao h2 {
  letter-spacing: -.02em;
}

.analysis-card-header p,
.strategic-action-card p,
.admin-panel-header p,
.page-subtitle,
.card p {
  line-height: 1.45;
}

/* Botões com hierarquia mais clara */
.btn-primario {
  border-radius: 15px !important;
  box-shadow: 0 12px 24px rgba(0,155,193,.16) !important;
}
.btn-primario:hover { transform: translateY(-2px); }
.btn-acao {
  border-radius: 14px !important;
  background: rgba(255,255,255,.72) !important;
}
.btn-acao:hover { transform: translateY(-1px); }

/* Menu flutuante mais discreto */
.menu-flutuante {
  border-radius: 24px !important;
  padding: 8px !important;
  box-shadow: 0 20px 45px rgba(0,0,0,.10) !important;
  backdrop-filter: blur(18px) saturate(1.08) !important;
}
.menu-flutuante button,
.menu-flutuante a {
  border-radius: 18px !important;
  min-height: 42px !important;
}
.menu-flutuante .active,
.menu-flutuante button.active,
.menu-flutuante a.active {
  box-shadow: 0 10px 22px rgba(0,155,193,.22) !important;
}

/* Header mais coeso */
.topbar.topbar-slim {
  box-shadow: 0 14px 30px rgba(0,0,0,.10) !important;
}
.topbar-program-logo {
  object-fit: contain !important;
  object-position: left center !important;
}
.brand-context strong { letter-spacing: -.01em !important; }
.global-search {
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.22) !important;
}
.global-search-results {
  border-radius: 18px !important;
  box-shadow: 0 18px 50px rgba(0,0,0,.16) !important;
}

/* Inputs e selects com padrão único */
input:not([type="checkbox"]):not([type="radio"]):not([type="color"]),
select,
textarea {
  border-radius: var(--radius-control) !important;
  transition: border-color .18s var(--ease-premium), box-shadow .18s var(--ease-premium), background-color .18s var(--ease-premium) !important;
}
input:not([type="checkbox"]):not([type="radio"]):not([type="color"]):focus,
select:focus,
textarea:focus {
  box-shadow: 0 0 0 4px rgba(0,155,193,.12) !important;
}

/* Modais com cabeçalho mais premium */
.modal-content,
.ficha-modal-shell {
  overflow: hidden;
}
.modal-content h2,
.ficha-modal-title,
.ficha-modal-shell h2 {
  letter-spacing: -.02em;
}
.modal-content .modal-actions,
.ficha-modal-footer {
  position: sticky;
  bottom: 0;
  z-index: 2;
  backdrop-filter: blur(12px);
}

/* Empty states mais consistentes */
.empty-state,
.tabela-vazia,
.lista-vazia,
.estado-vazio,
.empty-table-state {
  border-radius: 18px !important;
  border: 1px dashed rgba(0,155,193,.24) !important;
  background: linear-gradient(135deg, rgba(0,155,193,.06), rgba(0,179,126,.04)) !important;
  color: var(--text-light) !important;
}

/* Tema escuro: reduz cards claros e melhora contraste */
body[data-theme="dark"] {
  --surface-1: rgba(24,24,24,.94);
  --surface-2: rgba(30,30,30,.82);
  --line-soft: rgba(255,255,255,.10);
  --shadow-soft: 0 18px 45px rgba(0,0,0,.24);
  --shadow-hover: 0 22px 55px rgba(0,0,0,.34);
}
body[data-theme="dark"] .card,
body[data-theme="dark"] .analysis-card,
body[data-theme="dark"] .strategic-action-card,
body[data-theme="dark"] .program-health-card,
body[data-theme="dark"] .executive-kpi,
body[data-theme="dark"] .admin-panel-card,
body[data-theme="dark"] .admin-kpi-card,
body[data-theme="dark"] .quick-export-panel,
body[data-theme="dark"] .admin-control-hero,
body[data-theme="dark"] .podium-card {
  background: linear-gradient(145deg, rgba(30,30,30,.96), rgba(20,24,25,.94)) !important;
  border-color: rgba(255,255,255,.09) !important;
}
body[data-theme="dark"] .btn-acao {
  background: rgba(255,255,255,.06) !important;
  border-color: rgba(255,255,255,.12) !important;
}
body[data-theme="dark"] input:not([type="checkbox"]):not([type="radio"]):not([type="color"]),
body[data-theme="dark"] select,
body[data-theme="dark"] textarea {
  background: rgba(255,255,255,.06) !important;
  color: #f1f5f7 !important;
  border-color: rgba(255,255,255,.12) !important;
}
body[data-theme="dark"] .proximo-evento-item,
body[data-theme="dark"] .event-card,
body[data-theme="dark"] .evento-card,
body[data-theme="dark"] .next-event-card {
  background: linear-gradient(135deg, rgba(255,255,255,.06), rgba(0,155,193,.08)) !important;
  border-color: rgba(255,255,255,.12) !important;
  color: #f1f5f7 !important;
}
body[data-theme="dark"] .empty-state,
body[data-theme="dark"] .tabela-vazia,
body[data-theme="dark"] .lista-vazia,
body[data-theme="dark"] .estado-vazio,
body[data-theme="dark"] .empty-table-state {
  background: linear-gradient(135deg, rgba(0,155,193,.10), rgba(0,179,126,.06)) !important;
  border-color: rgba(0,155,193,.22) !important;
}

/* Pódio: nomes longos mais confortáveis */
.podium-item,
.podium-list-item,
.podium-row {
  min-width: 0 !important;
}
.podium-item strong,
.podium-list-item strong,
.podium-row strong,
#podiumBike strong,
#podiumCorrida strong {
  min-width: 0 !important;
  overflow: hidden !important;
  display: -webkit-box !important;
  -webkit-line-clamp: 2 !important;
  -webkit-box-orient: vertical !important;
  white-space: normal !important;
}

/* Radar: alerta menos agressivo */
.inactivity-card,
.radar-card,
.inactive-list li,
.alert-row {
  border-radius: 14px !important;
}
body[data-theme="dark"] .inactivity-card,
body[data-theme="dark"] .radar-card {
  background: rgba(230,57,70,.08) !important;
  border-color: rgba(230,57,70,.20) !important;
}

/* Drag and drop premium: reordenação dinâmica */
.fila-helper-v50,
.fila-helper {
  border-radius: 14px !important;
  background: linear-gradient(135deg, rgba(0,155,193,.08), rgba(0,179,126,.05)) !important;
  border: 1px solid rgba(0,155,193,.13) !important;
  padding: 10px 12px !important;
  margin: 8px 0 10px !important;
  color: var(--text-light) !important;
}
#listaFilaBike,
#listaFilaCorrida {
  position: relative;
}
#listaFilaBike.fila-dropzone-active,
#listaFilaCorrida.fila-dropzone-active {
  outline: 2px dashed rgba(0,155,193,.26);
  outline-offset: 6px;
  border-radius: 16px;
}
.fila-row {
  cursor: grab !important;
  transform-origin: center;
  transition: background-color .18s var(--ease-premium), box-shadow .18s var(--ease-premium), opacity .18s var(--ease-premium) !important;
}
.fila-row td {
  transition: background-color .18s var(--ease-premium), border-color .18s var(--ease-premium) !important;
}
.fila-row:hover td {
  background: rgba(0,155,193,.045) !important;
}
.fila-row.dragging {
  opacity: .55 !important;
  cursor: grabbing !important;
  filter: saturate(1.1);
}
.fila-row.dragging td {
  background: rgba(0,155,193,.12) !important;
  box-shadow: inset 4px 0 0 var(--primary) !important;
}
.fila-row .drag-handle {
  width: 26px !important;
  height: 26px !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  margin-right: 8px !important;
  border-radius: 10px !important;
  background: rgba(0,155,193,.08) !important;
  color: var(--primary) !important;
}
body[data-theme="dark"] .fila-row:hover td {
  background: rgba(0,155,193,.10) !important;
}
body[data-theme="dark"] .fila-row .drag-handle {
  background: rgba(0,155,193,.14) !important;
}

/* Admin: blocos com cara de centro de controle */
.admin-control-layout {
  align-items: start !important;
}
.admin-brand-card,
.admin-panel-card,
.admin-check-card {
  overflow: visible !important;
}
.admin-kpi-card {
  border-radius: 20px !important;
}
.admin-kpi-card strong {
  letter-spacing: -.03em;
}

/* Login/relacionamento visual com o portal */
@media (max-width: 720px) {
  .menu-flutuante {
    max-width: calc(100vw - 20px) !important;
    overflow-x: auto !important;
  }
  .menu-flutuante button,
  .menu-flutuante a {
    min-width: 44px !important;
  }
  .analysis-card,
  .card,
  .strategic-action-card,
  .admin-panel-card {
    border-radius: 20px !important;
  }
}

/* =====================================================
   V51 - Correção Drag & Drop + ajuste fino do header slim
   Escopo: corrigir DnD após re-render, remover linha azul no item
   arrastado e aproximar logo/texto sem aumentar altura do topo.
   ===================================================== */
.topbar.topbar-slim {
  height: 64px !important;
  min-height: 64px !important;
  padding-top: 7px !important;
  padding-bottom: 7px !important;
}

.topbar-brand {
  min-width: 285px !important;
  max-width: 355px !important;
  gap: 10px !important;
}

.topbar-program-logo {
  width: 122px !important;
  height: 38px !important;
}

.brand-divider {
  height: 28px !important;
  margin: 0 2px !important;
  opacity: .86 !important;
}

.brand-context strong {
  font-size: .98rem !important;
}

.brand-context small {
  font-size: .74rem !important;
  margin-top: 2px !important;
}

.fila-row.dragging,
.fila-row.dragging td {
  box-shadow: none !important;
  outline: none !important;
}

.fila-row.dragging td {
  background: rgba(0,155,193,.08) !important;
  border-color: rgba(0,155,193,.16) !important;
}

.fila-row.dragging .drag-handle {
  background: rgba(0,155,193,.18) !important;
  transform: scale(.96);
}

#listaFilaBike.fila-dropzone-active,
#listaFilaCorrida.fila-dropzone-active {
  outline: 1px dashed rgba(0,155,193,.22) !important;
  outline-offset: 4px !important;
}

/* =====================================================
   V52 — QA visual fino: pódio, header e identidade visual
   Escopo: corrigir cortes/overflow sem mexer em regra de negócio.
   ===================================================== */

/* Header slim preservado, mas sem área sobrando entre logo e texto */
.topbar.topbar-slim {
  height: 64px !important;
  min-height: 64px !important;
  padding-top: 7px !important;
  padding-bottom: 7px !important;
}

.topbar.topbar-slim .topbar-brand {
  min-width: 246px !important;
  max-width: 315px !important;
  gap: 8px !important;
  flex: 0 0 auto !important;
}

.topbar.topbar-slim .topbar-program-logo {
  width: 112px !important;
  height: 34px !important;
  object-fit: contain !important;
  object-position: left center !important;
  flex: 0 0 112px !important;
}

.topbar.topbar-slim .brand-divider {
  height: 26px !important;
  margin: 0 3px !important;
  opacity: .55 !important;
}

.topbar.topbar-slim .brand-context {
  min-width: 0 !important;
  line-height: 1.05 !important;
}

.topbar.topbar-slim .brand-context strong {
  font-size: .94rem !important;
  line-height: 1.1 !important;
  white-space: nowrap !important;
}

.topbar.topbar-slim .brand-context small {
  font-size: .70rem !important;
  line-height: 1.1 !important;
  margin-top: 2px !important;
}

/* Pódio: evita sensação de card cortado e separa nome/pontos */
.podium-card .podium-split {
  grid-template-columns: repeat(2, minmax(260px, 1fr)) !important;
  gap: 16px !important;
  align-items: stretch !important;
}

.podium-card .podium-split > div {
  min-width: 0 !important;
  overflow: hidden !important;
  border-radius: 22px !important;
}

.podium-card .podium-list {
  gap: 10px !important;
}

.podium-card .podium-list li,
.podium-card .podium-list li:first-child {
  min-height: 74px !important;
  height: auto !important;
  padding: 12px 14px !important;
  border-radius: 18px !important;
  overflow: visible !important;
}

.podium-card .podium-list li:first-child {
  min-height: 84px !important;
}

.podium-card .podium-rank {
  width: 100% !important;
  display: grid !important;
  grid-template-columns: 34px minmax(0, 1fr) 40px !important;
  gap: 12px !important;
  align-items: center !important;
}

.podium-card .podium-medal {
  width: 30px !important;
  height: 30px !important;
  flex: 0 0 30px !important;
}

.podium-card .podium-athlete {
  min-width: 0 !important;
  max-width: 100% !important;
  overflow: visible !important;
}

.podium-card .podium-athlete strong,
.podium-card .podium-list li strong {
  display: -webkit-box !important;
  -webkit-line-clamp: 2 !important;
  -webkit-box-orient: vertical !important;
  white-space: normal !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  line-height: 1.12 !important;
  max-height: 2.3em !important;
  padding-right: 2px !important;
  font-size: .88rem !important;
}

.podium-card .podium-athlete em {
  margin-top: 4px !important;
  line-height: 1.05 !important;
  white-space: nowrap !important;
}

.podium-card .podium-score {
  width: 36px !important;
  min-width: 36px !important;
  height: 32px !important;
  padding: 0 !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  justify-self: end !important;
  align-self: center !important;
  border-radius: 999px !important;
}

body[data-theme="dark"] .podium-card .podium-list li:first-child {
  background: linear-gradient(135deg, rgba(243,112,33,.14), rgba(0,155,193,.08)) !important;
  border-color: rgba(243,112,33,.28) !important;
}

/* Identidade visual no Admin: nada sobreposto e com respiro */
.admin-brand-card {
  overflow: hidden !important;
}

.admin-brand-card .brand-admin-grid,
.admin-brand-card .brand-editor-layout,
.admin-brand-card .brand-color-editor,
.admin-brand-card .brand-theme-preview,
.admin-brand-card .brand-admin-actions,
.admin-brand-card .brand-note-box {
  min-width: 0 !important;
  max-width: 100% !important;
  box-sizing: border-box !important;
}

.admin-brand-card .brand-admin-grid {
  grid-template-columns: repeat(2, minmax(230px, 1fr)) !important;
  gap: 16px !important;
}

.admin-brand-card .brand-preview {
  min-width: 0 !important;
  min-height: 166px !important;
}

.admin-brand-card .brand-preview img {
  max-width: 210px !important;
  width: 100% !important;
  height: 62px !important;
}

.admin-brand-card .brand-editor-layout {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) !important;
  gap: 16px !important;
}

.admin-brand-card .brand-color-editor {
  grid-template-columns: repeat(3, minmax(145px, 1fr)) !important;
}

.admin-brand-card .brand-color-editor label {
  min-width: 0 !important;
}

.admin-brand-card .brand-theme-preview {
  position: static !important;
  transform: none !important;
  width: 100% !important;
  max-width: 100% !important;
  justify-self: stretch !important;
  margin: 0 !important;
  z-index: auto !important;
}

.admin-brand-card .brand-admin-actions {
  margin-top: 16px !important;
}

@media (min-width: 1280px) {
  .admin-brand-card .brand-editor-layout {
    grid-template-columns: minmax(0, 1fr) minmax(340px, 430px) !important;
    align-items: start !important;
  }
  .admin-brand-card .brand-theme-preview {
    align-self: start !important;
  }
}

@media (max-width: 980px) {
  .topbar.topbar-slim .topbar-brand {
    min-width: 0 !important;
    max-width: none !important;
    flex: 1 1 auto !important;
  }
  .topbar.topbar-slim .topbar-program-logo {
    width: 108px !important;
    flex-basis: 108px !important;
  }
  .podium-card .podium-split,
  .admin-brand-card .brand-admin-grid,
  .admin-brand-card .brand-color-editor {
    grid-template-columns: 1fr !important;
  }
}

/* =====================================================
   V53 - QA visual real: correção de seletores conflitantes
   Corrige de forma mais forte o pódio, header e identidade visual.
   ===================================================== */

/* Header slim: logo e título próximos, sem reservar largura antiga */
.topbar.topbar-slim .topbar-brand,
header.topbar.topbar-slim .topbar-brand {
  min-width: 0 !important;
  width: auto !important;
  max-width: none !important;
  flex: 0 0 auto !important;
  gap: 8px !important;
  padding-right: 12px !important;
}

.topbar.topbar-slim .topbar-program-logo,
header.topbar.topbar-slim .topbar-program-logo {
  width: 96px !important;
  height: 32px !important;
  flex: 0 0 96px !important;
  object-fit: contain !important;
  object-position: left center !important;
  display: block !important;
}

.topbar.topbar-slim .brand-divider,
header.topbar.topbar-slim .brand-divider {
  height: 28px !important;
  margin-left: 2px !important;
  margin-right: 4px !important;
}

.topbar.topbar-slim .brand-context,
header.topbar.topbar-slim .brand-context {
  min-width: 130px !important;
  margin-left: 0 !important;
}

.topbar.topbar-slim .brand-context strong,
header.topbar.topbar-slim .brand-context strong {
  font-size: .94rem !important;
  line-height: 1.05 !important;
}

.topbar.topbar-slim .brand-context small,
header.topbar.topbar-slim .brand-context small {
  font-size: .70rem !important;
  line-height: 1.05 !important;
}

/* Pódio: remove regras antigas que criavam sobreposição/corte */
.podium-card .podium-list li:first-child::before,
.podium-card .podium-list li.podium-rank-1::before {
  content: none !important;
  display: none !important;
}

.podium-card .podium-list li:first-child > strong,
.podium-card .podium-list li.podium-rank-1 > strong {
  padding-right: 0 !important;
}

.podium-card .podium-split {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(260px, 1fr)) !important;
  gap: 16px !important;
  align-items: stretch !important;
}

.podium-card .podium-split > div {
  min-width: 0 !important;
  overflow: visible !important;
  padding: 16px !important;
}

.podium-card .podium-list,
#listaPodioBike,
#listaPodioCorrida {
  display: grid !important;
  gap: 12px !important;
  width: 100% !important;
  min-width: 0 !important;
  overflow: visible !important;
}

.podium-card .podium-list li.podium-rank,
.podium-card .podium-rank,
#listaPodioBike li,
#listaPodioCorrida li {
  display: grid !important;
  grid-template-columns: 34px minmax(0, 1fr) 38px !important;
  align-items: center !important;
  column-gap: 12px !important;
  min-width: 0 !important;
  width: 100% !important;
  min-height: 72px !important;
  height: auto !important;
  padding: 12px 12px !important;
  box-sizing: border-box !important;
  overflow: visible !important;
}

.podium-card .podium-list li.podium-rank-1,
.podium-card .podium-rank-1,
#listaPodioBike li:first-child,
#listaPodioCorrida li:first-child {
  min-height: 84px !important;
}

.podium-card .podium-medal {
  grid-column: 1 !important;
  justify-self: center !important;
  align-self: center !important;
  width: 30px !important;
  min-width: 30px !important;
  height: 30px !important;
}

.podium-card .podium-athlete {
  grid-column: 2 !important;
  min-width: 0 !important;
  width: 100% !important;
  overflow: visible !important;
  display: grid !important;
  gap: 4px !important;
}

.podium-card .podium-athlete strong,
.podium-card .podium-list li .podium-athlete strong {
  display: -webkit-box !important;
  -webkit-line-clamp: 2 !important;
  -webkit-box-orient: vertical !important;
  width: 100% !important;
  max-width: none !important;
  min-width: 0 !important;
  overflow: hidden !important;
  white-space: normal !important;
  text-overflow: ellipsis !important;
  line-height: 1.14 !important;
  max-height: none !important;
  padding: 0 !important;
  margin: 0 !important;
  word-break: normal !important;
}

.podium-card .podium-athlete em {
  display: block !important;
  min-width: 0 !important;
  max-width: 100% !important;
  overflow: hidden !important;
  white-space: nowrap !important;
  text-overflow: ellipsis !important;
  padding: 0 !important;
  margin: 0 !important;
}

.podium-card .podium-score,
.podium-card .podium-list li > strong.podium-score {
  grid-column: 3 !important;
  justify-self: end !important;
  align-self: center !important;
  width: 34px !important;
  min-width: 34px !important;
  height: 30px !important;
  padding: 0 !important;
  margin: 0 !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  overflow: visible !important;
}

@media (max-width: 1120px) {
  .podium-card .podium-split {
    grid-template-columns: 1fr !important;
  }
}

/* Identidade visual: a prévia fica abaixo dos campos, nunca sobreposta */
.admin-brand-card {
  overflow: visible !important;
}

.admin-brand-card .brand-editor-layout {
  display: block !important;
  margin-top: 18px !important;
}

.admin-brand-card .brand-color-editor {
  display: grid !important;
  grid-template-columns: repeat(4, minmax(128px, 1fr)) !important;
  gap: 12px !important;
  width: 100% !important;
  max-width: 100% !important;
  margin: 0 0 18px 0 !important;
}

.admin-brand-card .brand-color-editor label {
  min-width: 0 !important;
  min-height: 86px !important;
  padding: 12px !important;
  box-sizing: border-box !important;
}

.admin-brand-card .brand-theme-preview,
#brandPreviewTema.brand-theme-preview {
  position: static !important;
  display: grid !important;
  width: 100% !important;
  max-width: 720px !important;
  min-height: 0 !important;
  margin: 8px 0 0 0 !important;
  transform: none !important;
  inset: auto !important;
  z-index: 0 !important;
  box-sizing: border-box !important;
}

.admin-brand-card .brand-theme-top,
#brandPreviewTema .brand-theme-top {
  padding-bottom: 0 !important;
  margin-bottom: 14px !important;
}

.admin-brand-card .brand-theme-card,
#brandPreviewTema .brand-theme-card {
  margin: 0 !important;
}

.admin-brand-card .brand-admin-actions {
  margin-top: 18px !important;
}

.admin-brand-card .brand-admin-grid {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(220px, 1fr)) !important;
  gap: 16px !important;
}

.admin-brand-card .brand-preview {
  overflow: hidden !important;
}

.admin-brand-card .brand-preview img {
  max-width: 200px !important;
  height: 54px !important;
  object-fit: contain !important;
}

@media (max-width: 980px) {
  .admin-brand-card .brand-color-editor {
    grid-template-columns: repeat(2, minmax(130px, 1fr)) !important;
  }
}

@media (max-width: 640px) {
  .admin-brand-card .brand-admin-grid,
  .admin-brand-card .brand-color-editor {
    grid-template-columns: 1fr !important;
  }
}

/* =====================================================
   V54 - Informativo centralizado + modo apresentação
   ===================================================== */
.btn-apresentacao {
  border-color: rgba(0, 155, 193, .22) !important;
  background: linear-gradient(135deg, rgba(0,155,193,.08), rgba(0,179,126,.08)) !important;
}

.admin-config-grid-wide {
  grid-template-columns: repeat(2, minmax(180px, 1fr));
}

.admin-config-grid-wide input[type="number"] {
  width: 100%;
  height: 44px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--bg);
  color: var(--text);
  padding: 0 12px;
  font-weight: 700;
}

.admin-config-note {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-top: 14px;
  padding: 12px 14px;
  border-radius: 14px;
  background: rgba(0, 155, 193, .08);
  border: 1px solid rgba(0, 155, 193, .18);
  color: var(--text-light);
  font-weight: 700;
  font-size: .86rem;
}

.modal-informativo-grid-simple {
  grid-template-columns: repeat(2, minmax(220px, 1fr));
}

.modal-informativo-card .modal-informativo-note {
  margin-top: 18px;
}

body.dark-mode .admin-config-note,
body.dark-mode .btn-apresentacao {
  background: rgba(0, 155, 193, .12) !important;
  border-color: rgba(0, 155, 193, .26) !important;
}

@media (max-width: 760px) {
  .admin-config-grid-wide,
  .modal-informativo-grid-simple {
    grid-template-columns: 1fr;
  }
}

/* =====================================================
   V55 - QA de disposição + ícones outline
   Objetivo: evitar estouros/cortes e substituir emojis visuais do painel por Lucide outline.
   ===================================================== */

/* Base anti-overflow para áreas densas */
#estrategico,
#gestao,
.analysis-card,
.card,
.strategic-action-card,
.performance-compare,
.performance-compare > div,
.podium-card,
.podium-card * ,
.modality-engagement,
.agenda-item,
.agenda-info,
.admin-brand-card,
.admin-brand-card * {
  min-width: 0;
  box-sizing: border-box;
}

#estrategico strong,
#estrategico h4,
#estrategico p,
#estrategico span,
.agenda-info h4,
.perf-row strong {
  overflow-wrap: anywhere;
}

/* Chips/labels de modalidade usando ícones outline */
.outline-modality-label {
  display: inline-flex !important;
  align-items: center !important;
  gap: 7px !important;
  min-width: 0 !important;
  max-width: 100% !important;
  white-space: nowrap !important;
  color: var(--primary) !important;
  font-weight: 900 !important;
}

.outline-modality-label svg,
.modality-title svg,
.performance-compare h4 svg,
.podium-split h4 svg,
.flex-2-col h4 svg,
.agenda-info p svg,
.inactivity-name svg,
.strategic-action-icon svg {
  width: 17px !important;
  height: 17px !important;
  stroke-width: 2.3 !important;
  flex: 0 0 auto !important;
}

.performance-compare h4 .outline-modality-label,
.podium-split h4 .outline-modality-label,
.flex-2-col h4 .outline-modality-label {
  padding: 7px 12px !important;
  border: 1px solid rgba(0, 155, 193, .12) !important;
  border-radius: 999px !important;
  background: rgba(0, 155, 193, .045) !important;
}

[data-theme="dark"] .performance-compare h4 .outline-modality-label,
[data-theme="dark"] .podium-split h4 .outline-modality-label,
[data-theme="dark"] .flex-2-col h4 .outline-modality-label,
body.dark-mode .performance-compare h4 .outline-modality-label,
body.dark-mode .podium-split h4 .outline-modality-label,
body.dark-mode .flex-2-col h4 .outline-modality-label {
  background: rgba(0, 155, 193, .12) !important;
  border-color: rgba(0, 155, 193, .22) !important;
}

/* O pódio fica com largura útil maior para não cortar nomes */
.strategic-analysis-grid .podium-card {
  grid-column: 1 / -1 !important;
}

.podium-card .analysis-card-header {
  margin-bottom: 14px !important;
}

.podium-card .podium-split {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(340px, 1fr)) !important;
  gap: 18px !important;
  align-items: stretch !important;
}

.podium-card .podium-split > div {
  padding: 16px !important;
  border-radius: 22px !important;
  overflow: hidden !important;
}

.podium-card .podium-split h4 {
  margin: 0 0 12px 0 !important;
}

.podium-card .podium-list,
#listaPodioBike,
#listaPodioCorrida {
  display: grid !important;
  grid-template-columns: 1fr !important;
  gap: 10px !important;
  width: 100% !important;
  overflow: visible !important;
}

.podium-card .podium-list li.podium-rank,
.podium-card .podium-rank,
#listaPodioBike li,
#listaPodioCorrida li {
  position: relative !important;
  display: grid !important;
  grid-template-columns: 42px minmax(0, 1fr) 42px !important;
  align-items: center !important;
  gap: 12px !important;
  min-height: 66px !important;
  height: auto !important;
  padding: 12px 14px !important;
  border-radius: 18px !important;
  overflow: hidden !important;
}

.podium-card .podium-list li.podium-rank-1,
.podium-card .podium-rank-1,
#listaPodioBike li:first-child,
#listaPodioCorrida li:first-child {
  min-height: 74px !important;
  background: linear-gradient(135deg, rgba(243, 112, 33, .08), rgba(0, 155, 193, .055)) !important;
}

.podium-card .podium-medal {
  position: relative !important;
  width: 34px !important;
  height: 34px !important;
  border-radius: 50% !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  background: rgba(255,255,255,.78) !important;
  border: 1px solid rgba(0, 155, 193, .12) !important;
  color: var(--primary) !important;
  box-shadow: 0 8px 18px rgba(31,45,61,.08) !important;
}

.podium-card .podium-medal svg {
  width: 18px !important;
  height: 18px !important;
  stroke-width: 2.4 !important;
}

.podium-card .podium-medal b {
  position: absolute !important;
  right: -3px !important;
  bottom: -3px !important;
  width: 16px !important;
  height: 16px !important;
  border-radius: 999px !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: .62rem !important;
  line-height: 1 !important;
  background: var(--surface) !important;
  color: var(--text) !important;
  border: 1px solid var(--border) !important;
}

.podium-card .podium-medal-1 { color: #d99b00 !important; }
.podium-card .podium-medal-2 { color: #8e9aa7 !important; }
.podium-card .podium-medal-3 { color: #b86a2c !important; }

.podium-card .podium-athlete {
  display: grid !important;
  gap: 3px !important;
  min-width: 0 !important;
  overflow: hidden !important;
}

.podium-card .podium-athlete strong,
.podium-card .podium-list li .podium-athlete strong {
  display: -webkit-box !important;
  -webkit-line-clamp: 2 !important;
  -webkit-box-orient: vertical !important;
  white-space: normal !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  line-height: 1.12 !important;
  min-height: 0 !important;
  max-height: 2.35em !important;
  font-size: .96rem !important;
  letter-spacing: -.01em !important;
}

.podium-card .podium-athlete em {
  display: block !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
  max-width: 100% !important;
  font-size: .74rem !important;
  color: var(--text-light) !important;
}

.podium-card .podium-rank-1 .podium-athlete em {
  color: #b45412 !important;
}

.podium-card .podium-score,
.podium-card .podium-list li > strong.podium-score {
  width: 38px !important;
  min-width: 38px !important;
  height: 34px !important;
  border-radius: 999px !important;
  padding: 0 !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  justify-self: end !important;
  font-size: .85rem !important;
}

/* Dark mode: mantém contraste sem cards claros fora do padrão */
[data-theme="dark"] .podium-card .podium-medal,
body.dark-mode .podium-card .podium-medal {
  background: rgba(255,255,255,.08) !important;
  border-color: rgba(255,255,255,.12) !important;
}

[data-theme="dark"] .podium-card .podium-medal b,
body.dark-mode .podium-card .podium-medal b {
  background: rgba(20,20,20,.95) !important;
  border-color: rgba(255,255,255,.16) !important;
  color: rgba(255,255,255,.86) !important;
}

[data-theme="dark"] .podium-card .podium-rank-1 .podium-athlete em,
body.dark-mode .podium-card .podium-rank-1 .podium-athlete em {
  color: #f3a86b !important;
}

/* Performance e agenda: nomes longos não invadem outros blocos */
.performance-compare {
  grid-template-columns: repeat(2, minmax(260px, 1fr)) !important;
}

.perf-row {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) auto !important;
  gap: 12px !important;
  align-items: center !important;
}

.perf-row strong {
  min-width: 0 !important;
  max-width: 160px !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
  text-align: right !important;
}

.agenda-info p {
  display: flex !important;
  align-items: center !important;
  flex-wrap: wrap !important;
  gap: 6px !important;
}

.agenda-info h4 {
  min-width: 0 !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
}

/* Radar de inatividade com ícone outline e sem estouro */
.inactivity-name {
  display: grid !important;
  grid-template-columns: 18px minmax(0, 1fr) !important;
  align-items: center !important;
  gap: 8px !important;
  min-width: 0 !important;
}

.inactivity-name strong {
  min-width: 0 !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
}

.inactivity-name svg {
  color: var(--danger) !important;
}

/* Ações recomendadas com ícones outline */
.strategic-action-icon {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* Admin identidade visual: preview sempre abaixo ou lateral sem sobreposição */
.admin-brand-card .brand-editor-layout {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) !important;
  gap: 18px !important;
  align-items: start !important;
}

.admin-brand-card .brand-color-editor {
  display: grid !important;
  grid-template-columns: repeat(3, minmax(150px, 1fr)) !important;
  gap: 14px !important;
}

.admin-brand-card .brand-theme-preview,
#brandPreviewTema.brand-theme-preview {
  position: relative !important;
  inset: auto !important;
  transform: none !important;
  z-index: 1 !important;
  width: 100% !important;
  max-width: 760px !important;
  margin: 0 !important;
  align-self: start !important;
}

@media (min-width: 1180px) {
  .admin-brand-card .brand-editor-layout {
    grid-template-columns: minmax(0, 1fr) minmax(360px, 460px) !important;
  }
}

@media (max-width: 1080px) {
  .strategic-analysis-grid .podium-card {
    grid-column: auto !important;
  }
  .podium-card .podium-split,
  .performance-compare {
    grid-template-columns: 1fr !important;
  }
}

@media (max-width: 760px) {
  .admin-brand-card .brand-color-editor {
    grid-template-columns: repeat(2, minmax(130px, 1fr)) !important;
  }
  .podium-card .podium-list li.podium-rank,
  .podium-card .podium-rank,
  #listaPodioBike li,
  #listaPodioCorrida li {
    grid-template-columns: 38px minmax(0, 1fr) 38px !important;
    padding: 11px 12px !important;
  }
}

@media (max-width: 560px) {
  .admin-brand-card .brand-color-editor {
    grid-template-columns: 1fr !important;
  }
}

/* V56 - QA informativo centralizado + ícones outline */
.points-mini {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  color: var(--primary);
  font-weight: 800;
}
.points-mini svg,
.strike-badge svg,
.drag-handle svg,
.perm-item label svg,
.modal-informativo-note svg {
  width: 16px;
  height: 16px;
  flex: 0 0 auto;
}
.strike-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.drag-handle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  color: var(--text-light);
  cursor: grab;
}
.perm-item label {
  display: inline-flex !important;
  align-items: center;
  gap: 8px;
}
.modal-informativo-note-config {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  line-height: 1.45;
}
.modal-informativo-note-config span {
  min-width: 0;
}

/* =======================================================
   V57 - Refinamento final de disposição e anti-sobreposição
   Objetivo: corrigir espaços vazios, alinhamentos, cortes e áreas que invadem outras.
======================================================= */
:root {
  --layout-gap: 18px;
  --card-pad: 18px;
  --radius-xl: 22px;
}

/* Base anti-estouro */
*, *::before, *::after { box-sizing: border-box; }
main, section, .card, .analysis-card, .admin-panel-card, .modal-content, .ficha-modal-shell { min-width: 0; }
img, svg, canvas { max-width: 100%; }

/* Respiro inferior consistente para o menu flutuante */
main,
.admin-main,
.app-main,
#conteudoPrincipal {
  padding-bottom: clamp(96px, 10vh, 132px) !important;
}

/* Cabeçalhos de cards mais previsíveis */
.analysis-card,
.admin-panel-card,
.card {
  overflow: hidden;
}
.analysis-card-header,
.admin-panel-header,
.card-header {
  min-width: 0 !important;
}
.analysis-card-header h3,
.admin-panel-header h3,
.card-header h3 {
  min-width: 0 !important;
  line-height: 1.18 !important;
}
.analysis-card-header p,
.admin-panel-header p,
.card-header p {
  max-width: 720px;
  line-height: 1.45 !important;
}

/* Grid estratégico: melhora alinhamento e reduz buracos */
.strategic-analysis-grid {
  display: grid !important;
  grid-template-columns: minmax(420px, 1fr) minmax(420px, 1fr) !important;
  gap: var(--layout-gap) !important;
  align-items: stretch !important;
  grid-auto-flow: row dense !important;
}
.strategic-analysis-grid > .analysis-card {
  height: 100% !important;
  min-height: 0 !important;
  display: flex !important;
  flex-direction: column !important;
  gap: 14px !important;
}
.analysis-card-header {
  flex: 0 0 auto !important;
  min-height: 0 !important;
  margin-bottom: 0 !important;
}
.analysis-card > :not(.analysis-card-header) {
  min-width: 0 !important;
}

/* Performance por modalidade: remove cara de tabela apertada */
.performance-compare {
  width: 100% !important;
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 14px !important;
  align-items: stretch !important;
}
.performance-compare > div {
  min-width: 0 !important;
  height: 100% !important;
  padding: 16px !important;
  border-radius: 18px !important;
}
.performance-compare h4 {
  margin: 0 0 14px 0 !important;
  display: inline-flex !important;
  align-items: center !important;
  gap: 8px !important;
  max-width: 100% !important;
}
.perf-row {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) minmax(54px, auto) !important;
  align-items: center !important;
  gap: 10px !important;
  min-height: 34px !important;
}
.perf-row span,
.perf-row strong {
  min-width: 0 !important;
}
.perf-row strong {
  max-width: 180px !important;
  justify-self: end !important;
  text-align: right !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
}

/* Pódio: grid real, sem badge invadir nome e sem blocos cortando */
.podium-card .podium-split {
  width: 100% !important;
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 16px !important;
  align-items: stretch !important;
}
.podium-card .podium-split > div {
  min-width: 0 !important;
  overflow: hidden !important;
  display: flex !important;
  flex-direction: column !important;
}
.podium-card .podium-split h4 {
  width: fit-content !important;
  max-width: 100% !important;
  margin: 0 0 10px !important;
  padding: 8px 13px !important;
  border-radius: 999px !important;
  background: rgba(0,155,193,.07) !important;
  border: 1px solid rgba(0,155,193,.12) !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
}
.podium-card .podium-list {
  display: grid !important;
  grid-template-rows: repeat(3, minmax(72px, auto)) !important;
  gap: 10px !important;
  padding: 0 !important;
  margin: 0 !important;
}
.podium-card .podium-list li,
.podium-card .podium-list li.podium-rank,
#listaPodioBike > li,
#listaPodioCorrida > li {
  display: grid !important;
  grid-template-columns: 42px minmax(0, 1fr) 40px !important;
  align-items: center !important;
  gap: 10px !important;
  min-height: 72px !important;
  width: 100% !important;
  padding: 12px 12px !important;
  border-radius: 16px !important;
  overflow: hidden !important;
  border-bottom: 0 !important;
}
.podium-card .podium-list li.podium-rank-1 {
  min-height: 80px !important;
}
.podium-card .podium-medal {
  width: 34px !important;
  height: 34px !important;
  min-width: 34px !important;
  justify-self: center !important;
  overflow: visible !important;
}
.podium-card .podium-athlete {
  min-width: 0 !important;
  width: 100% !important;
  display: grid !important;
  gap: 4px !important;
  align-content: center !important;
  overflow: hidden !important;
}
.podium-card .podium-athlete strong {
  display: -webkit-box !important;
  -webkit-line-clamp: 2 !important;
  -webkit-box-orient: vertical !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: normal !important;
  line-height: 1.16 !important;
  max-height: 2.35em !important;
  padding-right: 0 !important;
}
.podium-card .podium-athlete em {
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
  line-height: 1.15 !important;
}
.podium-card .podium-score {
  width: 38px !important;
  height: 34px !important;
  min-width: 38px !important;
  justify-self: end !important;
  align-self: center !important;
  z-index: 1 !important;
}
.podium-card .podium-empty {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  min-height: 72px !important;
  border: 1px dashed var(--border) !important;
  border-radius: 16px !important;
  color: var(--text-light) !important;
}

/* Radar e eventos: evita chips, botões e textos invadindo */
.inactivity-grid,
.inactivity-columns,
.radar-inatividade-grid {
  min-width: 0 !important;
}
#listaEvasaoBike li,
#listaEvasaoCorrida li,
.inactivity-list li {
  min-width: 0 !important;
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) auto !important;
  align-items: center !important;
  gap: 8px !important;
  overflow: hidden !important;
}
#listaEvasaoBike li > *,
#listaEvasaoCorrida li > *,
.inactivity-list li > * {
  min-width: 0 !important;
}
#listaEvasaoBike li small,
#listaEvasaoCorrida li small,
.inactivity-list li small {
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  max-width: 120px !important;
}
#listaEventosAgenda {
  display: grid !important;
  gap: 12px !important;
}
#listaEventosAgenda .agenda-item,
#listaEventosAgenda .agenda-card-event {
  display: grid !important;
  grid-template-columns: 74px minmax(0, 1fr) !important;
  align-items: center !important;
  gap: 14px !important;
  width: 100% !important;
  min-width: 0 !important;
  overflow: hidden !important;
}
#listaEventosAgenda .agenda-data {
  width: 74px !important;
  min-width: 74px !important;
  height: 64px !important;
  display: grid !important;
  place-items: center !important;
}
#listaEventosAgenda .agenda-info,
#listaEventosAgenda .agenda-title-row {
  min-width: 0 !important;
  width: 100% !important;
}
#listaEventosAgenda .agenda-title-row {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) auto !important;
  align-items: center !important;
  gap: 8px !important;
}
#listaEventosAgenda .agenda-info h4 {
  min-width: 0 !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
}
#listaEventosAgenda .agenda-info p {
  min-width: 0 !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
}
#listaEventosAgenda .agenda-action {
  width: 34px !important;
  height: 34px !important;
  min-width: 34px !important;
}

/* Identidade visual admin: layout em faixas, sem sobreposição, sem espaço perdido */
.admin-brand-card {
  display: grid !important;
  gap: 18px !important;
  overflow: visible !important;
}
.admin-brand-card .brand-admin-grid {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(220px, 1fr)) !important;
  gap: 14px !important;
  align-items: stretch !important;
  margin: 0 !important;
}
.admin-brand-card .brand-preview {
  min-width: 0 !important;
  min-height: 164px !important;
  display: grid !important;
  grid-template-rows: auto 1fr auto !important;
  gap: 12px !important;
}
.admin-brand-card .brand-preview img {
  max-width: 220px !important;
  width: min(100%, 220px) !important;
  height: 64px !important;
  object-fit: contain !important;
  object-position: left center !important;
  align-self: center !important;
}
.admin-brand-card .brand-editor-layout {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) !important;
  gap: 16px !important;
  align-items: start !important;
  width: 100% !important;
  margin: 0 !important;
}
.admin-brand-card .brand-color-editor {
  display: grid !important;
  grid-template-columns: repeat(4, minmax(128px, 1fr)) !important;
  gap: 12px !important;
  width: 100% !important;
}
.admin-brand-card .brand-color-editor label {
  min-width: 0 !important;
  min-height: 86px !important;
  display: grid !important;
  grid-template-columns: 1fr !important;
  grid-template-rows: auto 40px !important;
  align-content: start !important;
  gap: 8px !important;
  overflow: hidden !important;
}
.admin-brand-card .brand-color-editor input[type="color"] {
  width: 100% !important;
  height: 40px !important;
}
.admin-brand-card .brand-theme-preview,
#brandPreviewTema.brand-theme-preview {
  position: static !important;
  transform: none !important;
  inset: auto !important;
  width: 100% !important;
  max-width: none !important;
  min-height: 0 !important;
  display: grid !important;
  grid-template-columns: 190px minmax(0, 1fr) !important;
  gap: 14px !important;
  align-items: stretch !important;
  padding: 14px !important;
  margin: 0 !important;
  z-index: 0 !important;
}
.admin-brand-card .brand-theme-top {
  grid-column: 1 / -1 !important;
}
.admin-brand-card .brand-theme-card {
  margin: 0 !important;
  min-width: 0 !important;
}
.admin-brand-card .brand-theme-preview code {
  align-self: end !important;
  min-width: 0 !important;
  overflow-wrap: anywhere !important;
}
.admin-brand-card .brand-admin-actions {
  display: flex !important;
  gap: 12px !important;
  align-items: center !important;
  flex-wrap: wrap !important;
  margin: 0 !important;
}
.admin-brand-card .brand-note-box {
  margin: 0 !important;
}

/* Formulários e modais: rodapé e controles não sobrepõem conteúdo */
.modal-content,
.modal-card,
.modal-panel {
  max-height: min(88vh, 820px) !important;
  overflow: auto !important;
  overscroll-behavior: contain !important;
}
.modal-content select,
.modal-content input,
.modal-content textarea,
.card select,
.card input,
.card textarea {
  min-width: 0 !important;
}
.modal-content .form-grid,
.card .form-grid {
  align-items: end !important;
}

/* Dark mode QA: evita cards claros em áreas escuras */
[data-theme="dark"] #listaEventosAgenda .agenda-card-event,
body.dark-mode #listaEventosAgenda .agenda-card-event {
  background: rgba(255,255,255,.045) !important;
  border-color: rgba(255,255,255,.10) !important;
  color: var(--text) !important;
}
[data-theme="dark"] #listaEventosAgenda .agenda-info p,
body.dark-mode #listaEventosAgenda .agenda-info p {
  color: rgba(255,255,255,.70) !important;
}
[data-theme="dark"] .performance-compare > div,
[data-theme="dark"] .podium-split > div,
body.dark-mode .performance-compare > div,
body.dark-mode .podium-split > div {
  background: rgba(255,255,255,.035) !important;
  border-color: rgba(255,255,255,.10) !important;
}

@media (min-width: 1320px) {
  .strategic-analysis-grid {
    grid-template-columns: minmax(500px, 1fr) minmax(500px, 1fr) !important;
  }
}

@media (max-width: 1180px) {
  .strategic-analysis-grid {
    grid-template-columns: 1fr !important;
  }
  .admin-brand-card .brand-color-editor {
    grid-template-columns: repeat(3, minmax(130px, 1fr)) !important;
  }
}

@media (max-width: 860px) {
  .performance-compare,
  .podium-card .podium-split,
  .admin-brand-card .brand-admin-grid {
    grid-template-columns: 1fr !important;
  }
  .admin-brand-card .brand-color-editor {
    grid-template-columns: repeat(2, minmax(130px, 1fr)) !important;
  }
  .admin-brand-card .brand-theme-preview,
  #brandPreviewTema.brand-theme-preview {
    grid-template-columns: 1fr !important;
  }
}

@media (max-width: 620px) {
  .analysis-card,
  .admin-panel-card,
  .card {
    padding: 16px !important;
    border-radius: 20px !important;
  }
  #listaEventosAgenda .agenda-item,
  #listaEventosAgenda .agenda-card-event {
    grid-template-columns: 58px minmax(0, 1fr) !important;
    gap: 10px !important;
  }
  #listaEventosAgenda .agenda-data {
    width: 58px !important;
    min-width: 58px !important;
    height: 58px !important;
  }
  .podium-card .podium-list li,
  .podium-card .podium-list li.podium-rank,
  #listaPodioBike > li,
  #listaPodioCorrida > li {
    grid-template-columns: 34px minmax(0, 1fr) 36px !important;
    gap: 8px !important;
    padding: 11px !important;
  }
  .admin-brand-card .brand-color-editor {
    grid-template-columns: 1fr !important;
  }
}

/* =====================================================
   V58 - Reorganização final de disposição
   Preenche buracos no dashboard, leva eventos para o grid
   estratégico e deixa Radar com o mesmo peso visual do Pódio.
   Também compacta o Admin em faixas mais equilibradas.
===================================================== */

/* Dashboard estratégico sem buracos: 3 linhas equilibradas em desktop */
#estrategico .strategic-analysis-grid {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 18px !important;
  align-items: stretch !important;
  grid-auto-flow: row dense !important;
}

#estrategico .strategic-analysis-grid > .analysis-card {
  min-width: 0 !important;
  height: 100% !important;
  min-height: 0 !important;
  margin: 0 !important;
}

#estrategico .analysis-wide {
  grid-row: auto !important;
  grid-column: auto !important;
}

#estrategico .analysis-card-header.compact {
  min-height: 68px !important;
  display: block !important;
}

#estrategico .analysis-card-header h3 {
  min-width: 0 !important;
  white-space: normal !important;
}

#estrategico .analysis-card-header p {
  margin-top: 4px !important;
  min-height: 18px !important;
}

/* Performance + Eventos: mesma presença visual na segunda linha */
#estrategico .performance-compare,
#estrategico .events-agenda-list {
  flex: 1 1 auto !important;
}

#estrategico .events-card {
  display: flex !important;
  flex-direction: column !important;
}

#estrategico .events-agenda-list,
#listaEventosAgenda.events-agenda-list {
  display: grid !important;
  gap: 12px !important;
  align-content: start !important;
  min-height: 0 !important;
  margin: 0 !important;
}

#estrategico .events-add-button {
  width: 100% !important;
  justify-content: center !important;
  margin-top: auto !important;
  min-height: 42px !important;
  border-style: dashed !important;
}

/* Agenda com visual coerente e sem elementos invadindo */
#listaEventosAgenda .agenda-card-event,
#listaEventosAgenda .agenda-item {
  display: grid !important;
  grid-template-columns: 70px minmax(0, 1fr) !important;
  gap: 14px !important;
  align-items: center !important;
  width: 100% !important;
  min-width: 0 !important;
  min-height: 78px !important;
  padding: 14px !important;
  border-radius: 18px !important;
  overflow: hidden !important;
}

#listaEventosAgenda .agenda-data {
  width: 64px !important;
  min-width: 64px !important;
  height: 62px !important;
  border-radius: 15px !important;
}

#listaEventosAgenda .agenda-info,
#listaEventosAgenda .agenda-title-row,
#listaEventosAgenda .agenda-info h4,
#listaEventosAgenda .agenda-info p {
  min-width: 0 !important;
}

#listaEventosAgenda .agenda-title-row {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) 34px !important;
  gap: 8px !important;
  align-items: center !important;
}

#listaEventosAgenda .agenda-info h4,
#listaEventosAgenda .agenda-info p {
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
}

/* Pódio e Radar com mesmo peso visual */
#estrategico .podium-card,
#estrategico .radar-card {
  min-height: 360px !important;
}

#estrategico .podium-card .podium-split,
#estrategico .radar-card .radar-columns {
  flex: 1 1 auto !important;
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 16px !important;
  min-width: 0 !important;
  align-items: stretch !important;
}

#estrategico .radar-card .radar-columns > div,
#estrategico .podium-card .podium-split > div {
  min-width: 0 !important;
  overflow: hidden !important;
  padding: 14px !important;
  border-radius: 20px !important;
  background:
    radial-gradient(circle at 95% 0%, rgba(0,155,193,.08), transparent 38%),
    rgba(0,155,193,.035) !important;
  border: 1px solid rgba(0,155,193,.11) !important;
}

#estrategico .radar-card h4,
#estrategico .podium-card h4 {
  width: fit-content !important;
  max-width: 100% !important;
  margin: 0 0 10px !important;
  padding: 7px 12px !important;
  border-radius: 999px !important;
  background: var(--bg-card) !important;
  border: 1px solid rgba(0,155,193,.14) !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

#listaEvasaoBike.inactivity-list,
#listaEvasaoCorrida.inactivity-list,
#estrategico .radar-card .inactivity-list {
  list-style: none !important;
  padding: 0 !important;
  margin: 0 !important;
  display: grid !important;
  gap: 8px !important;
  max-height: 238px !important;
  overflow: auto !important;
  scrollbar-width: thin !important;
}

#listaEvasaoBike.inactivity-list li,
#listaEvasaoCorrida.inactivity-list li,
#estrategico .radar-card .inactivity-list li {
  min-height: 44px !important;
  padding: 9px 10px !important;
  border-radius: 14px !important;
  background: rgba(230,57,70,.055) !important;
  border: 1px solid rgba(230,57,70,.12) !important;
}

#listaEvasaoBike.inactivity-list li small,
#listaEvasaoCorrida.inactivity-list li small {
  max-width: 112px !important;
}

/* Tema escuro: elimina cards claros e excesso de vermelho */
[data-theme="dark"] #estrategico .radar-card .radar-columns > div,
[data-theme="dark"] #estrategico .podium-card .podium-split > div,
body.dark-mode #estrategico .radar-card .radar-columns > div,
body.dark-mode #estrategico .podium-card .podium-split > div {
  background:
    radial-gradient(circle at 95% 0%, rgba(0,155,193,.14), transparent 40%),
    rgba(255,255,255,.035) !important;
  border-color: rgba(255,255,255,.10) !important;
}

[data-theme="dark"] #listaEvasaoBike.inactivity-list li,
[data-theme="dark"] #listaEvasaoCorrida.inactivity-list li,
body.dark-mode #listaEvasaoBike.inactivity-list li,
body.dark-mode #listaEvasaoCorrida.inactivity-list li {
  background: rgba(230,57,70,.075) !important;
  border-color: rgba(230,57,70,.18) !important;
}

/* Admin: grid sem buracos grandes e cards com alturas coerentes */
#sub-dados .admin-control-layout {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 18px !important;
  align-items: stretch !important;
  grid-auto-flow: row dense !important;
}

#sub-dados .admin-panel-card {
  min-width: 0 !important;
  height: 100% !important;
  margin: 0 !important;
}

#sub-dados .admin-brand-card,
#sub-dados .admin-danger-compact {
  grid-column: span 2 !important;
}

#sub-dados .admin-panel-header {
  min-height: 70px !important;
  align-items: flex-start !important;
}

#sub-dados .admin-kpi-grid {
  display: grid !important;
  grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
  gap: 12px !important;
}

#sub-dados .admin-kpi-card {
  min-width: 0 !important;
  height: 100% !important;
}

#sub-dados .admin-config-grid.admin-config-grid-wide {
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
}

#sub-dados .admin-config-checks {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 8px 12px !important;
}

#sub-dados .admin-brand-card .brand-editor-layout {
  grid-template-columns: minmax(0, 1.05fr) minmax(360px, .95fr) !important;
  align-items: start !important;
}

#sub-dados .admin-brand-card .brand-theme-preview,
#sub-dados #brandPreviewTema.brand-theme-preview {
  grid-template-columns: 1fr !important;
  align-self: start !important;
  position: sticky !important;
  top: 86px !important;
}

/* Responsivo: empilha sem buracos */
@media (max-width: 1180px) {
  #estrategico .strategic-analysis-grid,
  #sub-dados .admin-control-layout {
    grid-template-columns: 1fr !important;
  }

  #sub-dados .admin-brand-card,
  #sub-dados .admin-danger-compact {
    grid-column: auto !important;
  }

  #sub-dados .admin-kpi-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  }

  #sub-dados .admin-brand-card .brand-editor-layout {
    grid-template-columns: 1fr !important;
  }

  #sub-dados .admin-brand-card .brand-theme-preview,
  #sub-dados #brandPreviewTema.brand-theme-preview {
    position: static !important;
  }
}

@media (max-width: 760px) {
  #estrategico .performance-compare,
  #estrategico .podium-card .podium-split,
  #estrategico .radar-card .radar-columns,
  #sub-dados .admin-config-grid.admin-config-grid-wide,
  #sub-dados .admin-config-checks,
  #sub-dados .admin-kpi-grid {
    grid-template-columns: 1fr !important;
  }

  #estrategico .podium-card,
  #estrategico .radar-card {
    min-height: 0 !important;
  }
}

/* =====================================================
   V59 - QA Navegado: disposição final, anti-overflow e consistência
   Ajustes focados em evitar buracos, sobreposições e textos espremidos.
   ===================================================== */

/* Base anti-estouro para cards, grids e textos longos */
#estrategico *,
#sub-dados *,
.modal *,
.ficha-modal-shell * {
  box-sizing: border-box;
}

#estrategico .analysis-card,
#sub-dados .admin-panel-card,
#sub-dados .admin-kpi-card,
.card,
.modal-content,
.ficha-modal-shell {
  min-width: 0 !important;
}

#estrategico .analysis-card-header,
#sub-dados .admin-panel-header {
  gap: 10px !important;
}

#estrategico .analysis-card-header h3,
#estrategico .analysis-card-header p,
#sub-dados .admin-panel-header h3,
#sub-dados .admin-panel-header p,
.perf-row span,
.perf-row strong,
.podium-athlete strong,
.podium-athlete em,
.inactivity-list li,
.events-agenda-list * {
  min-width: 0 !important;
}

/* Estratégico: layout intencional sem card solto.
   Linha 1: engajamento em largura total.
   Linha 2: performance + eventos.
   Linha 3: pódio + radar. */
#estrategico .strategic-analysis-grid {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) !important;
  grid-auto-flow: row !important;
  align-items: start !important;
  gap: 18px !important;
}

#estrategico .strategic-analysis-grid > .analysis-card {
  align-self: stretch !important;
  height: auto !important;
  margin: 0 !important;
  overflow: hidden !important;
}

/* Engajamento por modalidade vira faixa de leitura rápida */
#estrategico .strategic-analysis-grid > .analysis-card:has(.modality-engagement-list) {
  grid-column: 1 / -1 !important;
}

#estrategico .modality-engagement-list {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 14px !important;
}

#estrategico .modality-engagement {
  min-width: 0 !important;
  overflow: hidden !important;
}

/* Performance: evita quebra feia em “Top atleta” e nomes longos */
#estrategico .performance-compare {
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 12px !important;
}

#estrategico .performance-compare > div {
  min-width: 0 !important;
  display: flex !important;
  flex-direction: column !important;
  gap: 2px !important;
  overflow: hidden !important;
}

#estrategico .perf-row {
  display: grid !important;
  grid-template-columns: minmax(92px, .9fr) minmax(0, 1fr) !important;
  align-items: center !important;
  gap: 10px !important;
  min-height: 34px !important;
}

#estrategico .perf-row span {
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

#estrategico .perf-row strong {
  max-width: none !important;
  justify-self: end !important;
  text-align: right !important;
  display: -webkit-box !important;
  -webkit-line-clamp: 2 !important;
  -webkit-box-orient: vertical !important;
  white-space: normal !important;
  line-height: 1.15 !important;
  overflow: hidden !important;
}

/* Eventos: botão e card sempre contidos */
#estrategico .events-card {
  min-height: 100% !important;
}

#listaEventosAgenda .agenda-card-event,
#listaEventosAgenda .agenda-item {
  grid-template-columns: 64px minmax(0, 1fr) !important;
  padding: 12px !important;
}

#listaEventosAgenda .agenda-data {
  width: 58px !important;
  min-width: 58px !important;
  height: 58px !important;
}

#listaEventosAgenda .agenda-title-row {
  grid-template-columns: minmax(0, 1fr) 30px !important;
}

#listaEventosAgenda .btn-icon,
#listaEventosAgenda button {
  max-width: 34px !important;
  overflow: hidden !important;
}

/* Pódio: remove aparência de card cortado e protege nome/badge */
#estrategico .podium-card,
#estrategico .radar-card {
  min-height: 380px !important;
  display: flex !important;
  flex-direction: column !important;
}

#estrategico .podium-card .podium-split,
#estrategico .radar-card .radar-columns {
  flex: 1 1 auto !important;
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 14px !important;
}

#estrategico .podium-card .podium-list {
  gap: 9px !important;
}

#estrategico .podium-card .podium-rank,
#estrategico .podium-card .podium-list li.podium-rank {
  grid-template-columns: 30px minmax(0, 1fr) 32px !important;
  gap: 10px !important;
  min-height: 64px !important;
  padding: 10px 12px !important;
  overflow: hidden !important;
  align-items: center !important;
}

#estrategico .podium-card .podium-rank-1,
#estrategico .podium-card .podium-list li.podium-rank-1 {
  min-height: 76px !important;
}

#estrategico .podium-card .podium-athlete {
  overflow: visible !important;
  padding-right: 2px !important;
}

#estrategico .podium-card .podium-athlete strong {
  display: -webkit-box !important;
  -webkit-box-orient: vertical !important;
  -webkit-line-clamp: 2 !important;
  white-space: normal !important;
  line-height: 1.12 !important;
  max-height: 2.35em !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  word-break: normal !important;
  hyphens: none !important;
}

#estrategico .podium-card .podium-athlete em {
  max-width: 100% !important;
  display: block !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

#estrategico .podium-card .podium-score {
  position: static !important;
  justify-self: end !important;
  align-self: center !important;
  z-index: 1 !important;
}

/* Radar: mesma largura do pódio, lista compacta e sem “vermelhão” */
#estrategico .radar-card .radar-columns > div {
  display: flex !important;
  flex-direction: column !important;
}

#estrategico .radar-card .inactivity-list {
  flex: 1 1 auto !important;
  max-height: 260px !important;
  padding-right: 4px !important;
}

#estrategico .radar-card .inactivity-list li {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) auto !important;
  gap: 8px !important;
  align-items: center !important;
}

#estrategico .radar-card .inactivity-list li strong,
#estrategico .radar-card .inactivity-list li span:first-child {
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
}

#estrategico .radar-card .inactivity-list li small {
  max-width: 96px !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

/* Admin: layout por áreas, reduz buracos e evita preview sobrepondo campos */
#sub-dados .admin-control-layout {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) !important;
  grid-template-areas:
    "saude informativo"
    "acessos acessos"
    "identidade identidade"
    "manutencao manutencao" !important;
  align-items: start !important;
  gap: 18px !important;
}

#sub-dados .admin-check-card { grid-area: saude !important; }
#sub-dados .admin-control-layout > .admin-panel-card:nth-of-type(2) { grid-area: informativo !important; }
#sub-dados .admin-control-layout > .admin-panel-card:nth-of-type(3) { grid-area: acessos !important; }
#sub-dados .admin-brand-card { grid-area: identidade !important; grid-column: auto !important; }
#sub-dados .admin-danger-compact { grid-area: manutencao !important; grid-column: auto !important; }

#sub-dados .admin-panel-header {
  min-height: 0 !important;
}

#sub-dados .admin-brand-card .brand-editor-layout {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 420px) !important;
  gap: 18px !important;
  align-items: start !important;
}

#sub-dados .admin-brand-card .brand-color-editor {
  grid-template-columns: repeat(2, minmax(150px, 1fr)) !important;
}

#sub-dados .admin-brand-card .brand-theme-preview,
#sub-dados #brandPreviewTema.brand-theme-preview {
  position: static !important;
  top: auto !important;
  align-self: start !important;
  width: 100% !important;
  max-width: none !important;
  margin: 0 !important;
  z-index: 0 !important;
}

#sub-dados .admin-brand-card .brand-admin-actions {
  border-top: 1px solid rgba(0,155,193,.10) !important;
  padding-top: 14px !important;
}

#sub-dados .admin-danger-actions {
  grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
}

#sub-dados .admin-danger-actions .btn-danger-soft {
  min-width: 0 !important;
  width: 100% !important;
  justify-content: flex-start !important;
}

/* Modais: rodapé sem cobrir conteúdo e controles sem estourar */
.modal-content {
  max-width: min(780px, calc(100vw - 28px)) !important;
  max-height: calc(100vh - 36px) !important;
  overflow: auto !important;
}

.modal-content .modal-actions,
.ficha-modal-footer {
  margin-top: 18px !important;
  padding-top: 12px !important;
  border-top: 1px solid rgba(0,155,193,.10) !important;
}

.modal-content select,
.modal-content input:not([type="checkbox"]):not([type="radio"]):not([type="color"]),
.modal-content textarea {
  max-width: 100% !important;
}

/* Tema escuro: contraste e coerência em cards internos */
body[data-theme="dark"] #estrategico .performance-compare > div,
body[data-theme="dark"] #estrategico .podium-card .podium-split > div,
body[data-theme="dark"] #estrategico .radar-card .radar-columns > div,
body[data-theme="dark"] #listaEventosAgenda .agenda-card-event,
body[data-theme="dark"] #listaEventosAgenda .agenda-item,
[data-theme="dark"] #estrategico .performance-compare > div,
[data-theme="dark"] #estrategico .podium-card .podium-split > div,
[data-theme="dark"] #estrategico .radar-card .radar-columns > div,
[data-theme="dark"] #listaEventosAgenda .agenda-card-event,
[data-theme="dark"] #listaEventosAgenda .agenda-item {
  background: linear-gradient(145deg, rgba(255,255,255,.055), rgba(0,155,193,.055)) !important;
  border-color: rgba(255,255,255,.10) !important;
}

body[data-theme="dark"] #estrategico .analysis-card-header p,
body[data-theme="dark"] #estrategico .perf-row span,
body[data-theme="dark"] #estrategico .podium-athlete em,
body[data-theme="dark"] #estrategico .radar-card .inactivity-list li small,
[data-theme="dark"] #estrategico .analysis-card-header p,
[data-theme="dark"] #estrategico .perf-row span,
[data-theme="dark"] #estrategico .podium-athlete em,
[data-theme="dark"] #estrategico .radar-card .inactivity-list li small {
  color: rgba(255,255,255,.68) !important;
}

/* Responsivo/tablet: empilha sem sobras artificiais */
@media (max-width: 1180px) {
  #estrategico .strategic-analysis-grid,
  #sub-dados .admin-control-layout {
    grid-template-columns: 1fr !important;
    grid-template-areas: none !important;
  }

  #estrategico .strategic-analysis-grid > .analysis-card:has(.modality-engagement-list),
  #sub-dados .admin-check-card,
  #sub-dados .admin-brand-card,
  #sub-dados .admin-danger-compact {
    grid-column: auto !important;
    grid-area: auto !important;
  }

  #sub-dados .admin-control-layout > .admin-panel-card {
    grid-area: auto !important;
  }

  #sub-dados .admin-brand-card .brand-editor-layout {
    grid-template-columns: 1fr !important;
  }
}

@media (max-width: 780px) {
  #estrategico .modality-engagement-list,
  #estrategico .performance-compare,
  #estrategico .podium-card .podium-split,
  #estrategico .radar-card .radar-columns,
  #sub-dados .admin-brand-card .brand-color-editor,
  #sub-dados .admin-danger-actions {
    grid-template-columns: 1fr !important;
  }

  #estrategico .podium-card,
  #estrategico .radar-card {
    min-height: 0 !important;
  }

  #estrategico .perf-row {
    grid-template-columns: minmax(0, 1fr) auto !important;
  }
}

/* =====================================================
   V60 — QA visual navegado: grid, lançamento, admin e lista de atletas
   ===================================================== */

/* Central do Comitê: ações sem corte e com hierarquia */
.quick-export-actions,
.quick-export-panel-v38 .quick-export-actions {
  display: flex !important;
  flex-wrap: wrap !important;
  align-items: stretch !important;
  justify-content: flex-start !important;
  gap: 10px !important;
  min-width: 0 !important;
}
.quick-export-actions .btn-acao,
.quick-export-actions .btn-primario,
.quick-export-panel-v38 .quick-export-actions .btn-acao,
.quick-export-panel-v38 .quick-export-actions .btn-primario {
  width: auto !important;
  min-width: 170px !important;
  max-width: 240px !important;
  height: 48px !important;
  padding: 0 16px !important;
  justify-content: center !important;
  white-space: nowrap !important;
  flex: 0 1 auto !important;
}
.quick-export-actions .btn-informativo-destaque {
  min-width: 220px !important;
}
.quick-export-actions #btnModoApresentacao {
  min-width: 195px !important;
}
@media (max-width: 760px) {
  .quick-export-actions .btn-acao,
  .quick-export-actions .btn-primario,
  .quick-export-panel-v38 .quick-export-actions .btn-acao,
  .quick-export-panel-v38 .quick-export-actions .btn-primario {
    flex: 1 1 calc(50% - 10px) !important;
    max-width: none !important;
    min-width: 0 !important;
  }
}
@media (max-width: 520px) {
  .quick-export-actions .btn-acao,
  .quick-export-actions .btn-primario,
  .quick-export-panel-v38 .quick-export-actions .btn-acao,
  .quick-export-panel-v38 .quick-export-actions .btn-primario {
    flex-basis: 100% !important;
  }
}

/* Estratégico: remove buracos e equilibra faixas */
#visao-geral .strategic-analysis-grid {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) !important;
  grid-auto-flow: dense !important;
  gap: 18px !important;
  align-items: stretch !important;
}
#visao-geral .analysis-card {
  min-width: 0 !important;
  height: 100% !important;
}
#visao-geral .modality-card,
#visao-geral .modality-engagement-card,
#visao-geral .engagement-card,
#visao-geral .analysis-card:has(#dashBikeEngBar) {
  grid-column: 1 / -1 !important;
}
#visao-geral .performance-compare {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 12px !important;
}
#visao-geral .performance-compare > div {
  min-width: 0 !important;
}
#visao-geral .events-card {
  grid-column: auto !important;
}
#visao-geral .podium-card,
#visao-geral .radar-card {
  grid-column: 1 / -1 !important;
}
#visao-geral .podium-split,
#visao-geral .radar-columns {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 16px !important;
}
#visao-geral .radar-columns > div,
#visao-geral .podium-split > div {
  min-width: 0 !important;
  border: 1px solid rgba(0,155,193,.10) !important;
  border-radius: 18px !important;
  padding: 14px !important;
  background: rgba(0,155,193,.025) !important;
}
#visao-geral .inactivity-list {
  display: grid !important;
  gap: 8px !important;
  max-height: 280px !important;
  overflow-y: auto !important;
  padding-right: 4px !important;
}
#visao-geral .inactivity-list li,
#visao-geral .podium-list li,
#visao-geral .podium-rank {
  min-width: 0 !important;
}
#visao-geral .inactivity-list li {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) auto !important;
  gap: 10px !important;
  align-items: center !important;
}
#visao-geral .inactivity-list li span:first-child,
#visao-geral .podium-athlete strong,
#visao-geral .perf-row strong {
  min-width: 0 !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
}
#visao-geral .events-agenda-list {
  display: grid !important;
  gap: 10px !important;
}
#visao-geral .agenda-card-event,
#visao-geral .evento-card,
#visao-geral .next-event-card,
#visao-geral .proximo-evento-item {
  min-width: 0 !important;
  overflow: hidden !important;
}
#visao-geral .agenda-info,
#visao-geral .agenda-info p,
#visao-geral .agenda-info strong {
  min-width: 0 !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}
@media (max-width: 980px) {
  #visao-geral .strategic-analysis-grid,
  #visao-geral .performance-compare,
  #visao-geral .podium-split,
  #visao-geral .radar-columns {
    grid-template-columns: 1fr !important;
  }
}

/* Lançamento: tabela completa na página e botão abaixo da lista */
#areaTabelaPontuacao {
  overflow: visible !important;
}
#areaTabelaPontuacao .tabela-container {
  max-height: none !important;
  overflow-y: visible !important;
  overflow-x: auto !important;
  box-shadow: var(--shadow) !important;
}
#areaTabelaPontuacao .tabela-simples {
  margin-bottom: 0 !important;
}
.lancamento-save-bar {
  position: static !important;
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  gap: 14px !important;
  margin: 14px 0 28px !important;
  padding: 14px 16px !important;
  border-radius: 18px !important;
  background: var(--bg-card) !important;
  border: 1px solid rgba(0,155,193,.12) !important;
  box-shadow: var(--shadow) !important;
}
.lancamento-save-bar .btn-primario {
  min-width: 220px !important;
  height: 48px !important;
}
.lancamento-save-bar small {
  flex: 1 !important;
  text-align: right !important;
  color: var(--text-light) !important;
}
@media (max-width: 720px) {
  .lancamento-save-bar {
    flex-direction: column !important;
    align-items: stretch !important;
  }
  .lancamento-save-bar small { text-align: left !important; }
}

/* Admin: evita sobreposição e reduz buracos na identidade visual */
#sub-dados .admin-control-layout {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) !important;
  grid-template-areas:
    "saude informativo"
    "acessos acessos"
    "identidade identidade"
    "manutencao manutencao" !important;
  gap: 18px !important;
  align-items: start !important;
}
#sub-dados .admin-check-card { grid-area: saude !important; }
#sub-dados .admin-control-layout > .admin-panel-card:nth-of-type(2) { grid-area: informativo !important; }
#sub-dados .admin-control-layout > .admin-panel-card:nth-of-type(3) { grid-area: acessos !important; }
#sub-dados .admin-brand-card { grid-area: identidade !important; grid-column: auto !important; }
#sub-dados .admin-danger-compact { grid-area: manutencao !important; grid-column: auto !important; }
#sub-dados .admin-brand-card .brand-editor-layout {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 420px) !important;
  gap: 18px !important;
  align-items: start !important;
}
#sub-dados .admin-brand-card .brand-color-editor {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(150px, 1fr)) !important;
  gap: 12px !important;
  min-width: 0 !important;
}
#sub-dados .admin-brand-card .brand-color-editor label {
  min-width: 0 !important;
}
#sub-dados .admin-brand-card .brand-theme-preview,
#sub-dados #brandPreviewTema.brand-theme-preview {
  position: static !important;
  top: auto !important;
  align-self: start !important;
  width: 100% !important;
  max-width: none !important;
  margin: 0 !important;
  z-index: 0 !important;
}
#sub-dados .admin-brand-card .brand-admin-actions {
  display: flex !important;
  flex-wrap: wrap !important;
  gap: 10px !important;
  margin-top: 14px !important;
}
#sub-dados .brand-note-box {
  margin-top: 12px !important;
}
@media (max-width: 1180px) {
  #sub-dados .admin-control-layout {
    grid-template-columns: 1fr !important;
    grid-template-areas:
      "saude"
      "informativo"
      "acessos"
      "identidade"
      "manutencao" !important;
  }
  #sub-dados .admin-brand-card .brand-editor-layout {
    grid-template-columns: 1fr !important;
  }
  #sub-dados .admin-brand-card .brand-color-editor {
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  }
}
@media (max-width: 640px) {
  #sub-dados .admin-brand-card .brand-color-editor {
    grid-template-columns: 1fr !important;
  }
}

/* Tela Atletas: alternância cards/lista */
.athlete-filter-head {
  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
  gap: 14px !important;
  margin-bottom: 14px !important;
  padding-bottom: 12px !important;
  border-bottom: 1px solid rgba(0,155,193,.10) !important;
}
.athlete-filter-head strong {
  display: block !important;
  color: var(--text) !important;
  font-size: .95rem !important;
}
.athlete-filter-head span {
  display: block !important;
  color: var(--text-light) !important;
  font-size: .82rem !important;
  margin-top: 2px !important;
}
.view-toggle {
  display: inline-flex !important;
  align-items: center !important;
  gap: 6px !important;
  padding: 5px !important;
  border-radius: 999px !important;
  background: rgba(0,155,193,.06) !important;
  border: 1px solid rgba(0,155,193,.12) !important;
  flex-shrink: 0 !important;
}
.view-toggle-btn {
  border: 0 !important;
  background: transparent !important;
  color: var(--text-light) !important;
  border-radius: 999px !important;
  height: 36px !important;
  padding: 0 12px !important;
  display: inline-flex !important;
  align-items: center !important;
  gap: 6px !important;
  font-weight: 700 !important;
  cursor: pointer !important;
  transition: .18s ease !important;
}
.view-toggle-btn svg { width: 16px !important; height: 16px !important; }
.view-toggle-btn.active {
  background: var(--primary) !important;
  color: #fff !important;
  box-shadow: 0 8px 18px rgba(0,155,193,.18) !important;
}
.athlete-card-grid.athlete-list-mode {
  display: block !important;
}
.athlete-list-wrapper {
  max-height: none !important;
  overflow-y: visible !important;
  overflow-x: auto !important;
}
.athlete-list-table td:first-child strong,
.athlete-list-table td:first-child small {
  display: block !important;
  max-width: 360px !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  white-space: nowrap !important;
}
.athlete-list-table td:first-child small {
  margin-top: 3px !important;
  color: var(--text-light) !important;
  font-size: .74rem !important;
}
.athlete-list-row {
  cursor: pointer !important;
}
.athlete-list-row:hover {
  background: rgba(0,155,193,.045) !important;
}
.status-badge {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  min-height: 24px !important;
  padding: 4px 9px !important;
  border-radius: 999px !important;
  font-size: .72rem !important;
  font-weight: 800 !important;
  background: rgba(0,155,193,.10) !important;
  color: var(--primary) !important;
  white-space: nowrap !important;
}
.status-badge.run { background: rgba(0,179,126,.11) !important; color: var(--secondary) !important; }
.status-badge.active { background: rgba(0,179,126,.12) !important; color: var(--secondary) !important; }
.status-badge.inactive { background: rgba(230,57,70,.10) !important; color: var(--danger) !important; }
@media (max-width: 760px) {
  .athlete-filter-head {
    flex-direction: column !important;
    align-items: stretch !important;
  }
  .view-toggle { align-self: flex-start !important; }
}

/* Dark mode específico para blocos refinados */
[data-theme="dark"] #visao-geral .radar-columns > div,
[data-theme="dark"] #visao-geral .podium-split > div,
body.dark-mode #visao-geral .radar-columns > div,
body.dark-mode #visao-geral .podium-split > div {
  background: rgba(255,255,255,.035) !important;
  border-color: rgba(255,255,255,.09) !important;
}
[data-theme="dark"] .lancamento-save-bar,
body.dark-mode .lancamento-save-bar {
  background: var(--bg-card) !important;
  border-color: rgba(255,255,255,.10) !important;
}



/* =====================================================
   VISÃO ESTRATÉGICA — Imersiva V4
   ===================================================== */

/* ── Tokens da seção ────────────────────────────────── */
#visao-geral {
  --clr-bike:    #009bc1;
  --clr-corrida: #00b37e;
  --clr-warn:    #f37021;
  --clr-danger:  #e63946;
  --gap: 18px;
}

/* ── Cabeçalho ──────────────────────────────────────── */
.vg-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
  margin-bottom: 20px;
}

.vg-header__title {
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -.025em;
  margin: 0 0 3px;
}

.vg-header__sub {
  font-size: .82rem;
  color: var(--text-light);
  margin: 0;
}

/* ── Banner de status ───────────────────────────────── */
.vg-status-banner {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 11px 16px;
  border-radius: 12px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  font-size: .82rem;
  color: var(--text-light);
  margin-bottom: var(--gap);
  transition: border-color .3s, background .3s;
}

.vg-status-banner__dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #94a3b8;
  flex-shrink: 0;
  box-shadow: 0 0 0 3px rgba(148,163,184,.2);
  transition: background .3s, box-shadow .3s;
}

.vg-status-banner[data-state="good"] {
  background: rgba(0,179,126,.05);
  border-color: rgba(0,179,126,.22);
}
.vg-status-banner[data-state="good"] #vgStatusText { color: var(--clr-corrida); font-weight: 600; }
.vg-status-banner[data-state="good"] .vg-status-banner__dot { background: var(--clr-corrida); box-shadow: 0 0 0 3px rgba(0,179,126,.2); }

.vg-status-banner[data-state="warn"] {
  background: rgba(243,112,33,.05);
  border-color: rgba(243,112,33,.22);
}
.vg-status-banner[data-state="warn"] #vgStatusText { color: var(--clr-warn); font-weight: 600; }
.vg-status-banner[data-state="warn"] .vg-status-banner__dot { background: var(--clr-warn); box-shadow: 0 0 0 3px rgba(243,112,33,.2); }

.vg-status-banner[data-state="danger"] {
  background: rgba(230,57,70,.05);
  border-color: rgba(230,57,70,.22);
}
.vg-status-banner[data-state="danger"] #vgStatusText { color: var(--clr-danger); font-weight: 600; }
.vg-status-banner[data-state="danger"] .vg-status-banner__dot { background: var(--clr-danger); box-shadow: 0 0 0 3px rgba(230,57,70,.2); }

.vg-status-banner__sep { opacity: .3; }

/* ── Hero card ──────────────────────────────────────── */
.vg-hero {
  display: flex;
  align-items: center;
  gap: 32px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 22px;
  padding: 28px 32px;
  margin-bottom: var(--gap);
  box-shadow: var(--shadow);
  overflow: hidden;
  position: relative;
}

.vg-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at 8% 50%, rgba(0,155,193,.07) 0%, transparent 40%),
    radial-gradient(circle at 95% 20%, rgba(0,179,126,.06) 0%, transparent 40%);
}

/* Anel SVG */
.vg-hero__engagement {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.vg-ring {
  position: relative;
  width: 100px;
  height: 100px;
  flex-shrink: 0;
}

.vg-ring__svg {
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.vg-ring__track {
  fill: none;
  stroke: var(--border);
  stroke-width: 8;
}

.vg-ring__fill {
  fill: none;
  stroke: var(--clr-corrida);
  stroke-width: 8;
  stroke-linecap: round;
  stroke-dasharray: 251.2;
  stroke-dashoffset: 251.2;
  transition: stroke-dashoffset .8s cubic-bezier(.4,0,.2,1), stroke .4s;
}

.vg-ring__label {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1px;
}

.vg-ring__label strong {
  font-size: 1.35rem;
  font-weight: 800;
  color: var(--text);
  line-height: 1;
  letter-spacing: -.03em;
}

.vg-ring__label span {
  font-size: .6rem;
  font-weight: 700;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: .06em;
}

.vg-hero__eng-copy {
  min-width: 0;
}

.vg-hero__eng-title {
  font-size: .7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--text-light);
  margin: 0 0 5px;
}

.vg-hero__eng-sub {
  font-size: .9rem;
  color: var(--text);
  margin: 0 0 5px;
}

.vg-hero__eng-sub b { font-weight: 700; }

.vg-hero__eng-tend {
  font-size: .78rem;
  color: var(--text-light);
  margin: 0;
  font-style: italic;
}

/* Divisória */
.vg-hero__divider {
  width: 1px;
  align-self: stretch;
  background: var(--border);
  flex-shrink: 0;
  margin: 0 8px;
  position: relative;
  z-index: 1;
}

/* KPIs do hero */
.vg-hero__kpis {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  flex: 1;
  position: relative;
  z-index: 1;
}

.vg-hero__kpi {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  background: var(--bg);
  border-radius: 14px;
  border: 1px solid var(--border);
  transition: transform .15s, box-shadow .15s;
}

.vg-hero__kpi:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 18px rgba(0,0,0,.08);
}

.vg-hero__kpi > i,
.vg-hero__kpi > svg {
  width: 18px;
  height: 18px;
  color: var(--primary);
  flex-shrink: 0;
}

.vg-hero__kpi strong {
  display: block;
  font-size: 1.05rem;
  font-weight: 800;
  color: var(--text);
  line-height: 1.1;
  letter-spacing: -.02em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.vg-hero__kpi span {
  display: block;
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .05em;
  color: var(--text-light);
  margin-top: 2px;
  white-space: nowrap;
}

/* ── Seção auxiliar ─────────────────────────────────── */
.vg-section-title {
  margin: 0 0 3px;
  font-size: .9rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 7px;
  color: var(--text);
  letter-spacing: -.01em;
}

.vg-section-title i,
.vg-section-title svg { width: 15px; height: 15px; color: var(--primary); }

.vg-section-desc {
  font-size: .78rem;
  color: var(--text-light);
  margin: 0;
}

.vg-section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 16px;
}

.vg-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 20px 22px;
  box-shadow: var(--shadow);
}

/* ── Conteúdo principal: gráfico + sidebar ──────────── */
.vg-content {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: var(--gap);
  margin-bottom: var(--gap);
  align-items: start;
}

.vg-chart-wrap {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 22px;
  box-shadow: var(--shadow);
}

.vg-chart-shell {
  height: 290px;
  position: relative;
}

.vg-trend-pill {
  font-size: .72rem;
  font-weight: 700;
  padding: 5px 12px;
  border-radius: 999px;
  background: rgba(0,155,193,.08);
  border: 1px solid rgba(0,155,193,.16);
  color: var(--primary);
  white-space: nowrap;
  flex-shrink: 0;
}

/* Sidebar */
.vg-sidebar {
  display: flex;
  flex-direction: column;
  gap: var(--gap);
}

/* Ações */
.vg-count-pills {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.vg-cpill {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: .7rem;
  font-weight: 700;
  padding: 4px 9px;
  border-radius: 999px;
  background: var(--bg);
  border: 1px solid var(--border);
  color: var(--text-light);
}

.vg-cpill b { color: var(--text); }

.vg-cpill--warn {
  background: rgba(243,112,33,.07);
  border-color: rgba(243,112,33,.22);
  color: var(--clr-warn);
}

.vg-cpill--warn b { color: var(--clr-warn); }

/* Botão novo evento */
.vg-btn-new {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 6px 13px;
  border-radius: 999px;
  border: 1px solid rgba(0,155,193,.22);
  background: rgba(0,155,193,.07);
  color: var(--primary);
  font-size: .76rem;
  font-weight: 600;
  cursor: pointer;
  font-family: inherit;
  transition: background .15s, transform .1s;
  white-space: nowrap;
  width: auto;
  min-height: unset;
}

.vg-btn-new:hover { background: rgba(0,155,193,.14); transform: none; box-shadow: none; }
.vg-btn-new i, .vg-btn-new svg { width: 13px; height: 13px; }

.vg-sub-label {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: .72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--text-light);
  margin: 0 0 10px;
}

.vg-sub-label i, .vg-sub-label svg { width: 12px; height: 12px; }

/* ── Modalidades ────────────────────────────────────── */
.vg-modalities {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--gap);
  margin-bottom: var(--gap);
}

.vg-mod {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 24px;
  box-shadow: var(--shadow);
  position: relative;
  overflow: hidden;
}

.vg-mod::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  border-radius: 20px 20px 0 0;
}

.vg-mod--bike::after    { background: linear-gradient(90deg, var(--clr-bike), #00a693); }
.vg-mod--corrida::after { background: linear-gradient(90deg, var(--clr-corrida), #7ac943); }

.vg-mod__top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20px;
}

.vg-mod__identity {
  display: flex;
  align-items: center;
  gap: 14px;
}

.vg-mod__icon {
  width: 46px;
  height: 46px;
  border-radius: 14px;
  display: grid;
  place-items: center;
}

.vg-mod--bike .vg-mod__icon {
  background: rgba(0,155,193,.1);
  color: var(--clr-bike);
}

.vg-mod--corrida .vg-mod__icon {
  background: rgba(0,179,126,.1);
  color: var(--clr-corrida);
}

.vg-mod__icon i, .vg-mod__icon svg { width: 22px; height: 22px; }

.vg-mod__name {
  font-size: .72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .07em;
  color: var(--text-light);
  margin: 0 0 3px;
}

.vg-mod__count {
  font-size: .95rem;
  color: var(--text);
  margin: 0;
}

.vg-mod__count strong {
  font-size: 1.6rem;
  font-weight: 800;
  letter-spacing: -.04em;
}

.vg-mod--bike .vg-mod__count strong    { color: var(--clr-bike); }
.vg-mod--corrida .vg-mod__count strong { color: var(--clr-corrida); }

.vg-mod__eng-block {
  text-align: right;
  line-height: 1.1;
}

.vg-mod__eng-block strong {
  display: block;
  font-size: 1.55rem;
  font-weight: 800;
  letter-spacing: -.04em;
}

.vg-mod--bike .vg-mod__eng-block strong    { color: var(--clr-bike); }
.vg-mod--corrida .vg-mod__eng-block strong { color: var(--clr-corrida); }

.vg-mod__eng-block span {
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--text-light);
}

.vg-mod__bar {
  height: 7px;
  background: var(--border);
  border-radius: 999px;
  overflow: hidden;
  margin-bottom: 8px;
}

.vg-mod__bar-fill {
  height: 100%;
  border-radius: 999px;
  width: 0;
  transition: width .6s cubic-bezier(.4,0,.2,1);
}

.vg-mod--bike .vg-mod__bar-fill {
  background: linear-gradient(90deg, var(--clr-bike), #00a693);
}

.vg-mod--corrida .vg-mod__bar-fill {
  background: linear-gradient(90deg, var(--clr-corrida), #7ac943);
}

.vg-mod__bar-meta {
  font-size: .76rem;
  color: var(--text-light);
  margin: 0 0 20px;
}

.vg-mod__stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  padding: 18px 0;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  margin-bottom: 14px;
}

.vg-mod__stat span {
  display: block;
  font-size: .65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .05em;
  color: var(--text-light);
  margin-bottom: 4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.vg-mod__stat strong {
  font-size: .95rem;
  font-weight: 700;
  color: var(--text);
}

.vg-mod__top-athlete {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: .82rem;
  color: var(--text-light);
}

.vg-mod__top-athlete i,
.vg-mod__top-athlete svg { width: 14px; height: 14px; color: #f59e0b; }

.vg-mod__top-athlete strong {
  color: var(--text);
  font-weight: 600;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ── Pódio + Radar ──────────────────────────────────── */
.vg-bottom {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--gap);
  margin-bottom: var(--gap);
}

.vg-podium-cols,
.vg-radar-cols {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

/* ── Command: financeiro + exports ──────────────────── */
.vg-command {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: var(--gap);
  margin-bottom: var(--gap);
}

.vg-fin-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 14px;
}

.vg-fin-cell {
  background: var(--bg);
  border-radius: 12px;
  padding: 12px 14px;
  border: 1px solid var(--border);
}

.vg-fin-cell span {
  display: block;
  font-size: .67rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .05em;
  color: var(--text-light);
  margin-bottom: 4px;
}

.vg-fin-cell strong {
  font-size: .95rem;
  font-weight: 700;
  color: var(--text);
}

/* Grid de exports */
.vg-export-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-top: 14px;
}

.vg-export-btn {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6px;
  padding: 14px 16px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 14px;
  cursor: pointer;
  font-family: inherit;
  text-align: left;
  transition: background .15s, border-color .15s, transform .12s, box-shadow .15s;
  width: 100%;
  min-height: unset;
  color: var(--text);
}

.vg-export-btn:hover {
  background: var(--bg-card);
  border-color: rgba(0,155,193,.3);
  transform: translateY(-2px);
  box-shadow: 0 6px 18px rgba(0,0,0,.08);
}

.vg-export-btn i,
.vg-export-btn svg {
  width: 18px;
  height: 18px;
  color: var(--primary);
}

.vg-export-btn--primary {
  background: linear-gradient(135deg, rgba(0,155,193,.1), rgba(0,179,126,.06));
  border-color: rgba(0,155,193,.22);
}

.vg-export-btn--primary i,
.vg-export-btn--primary svg { color: var(--primary); }

.vg-export-btn__label {
  font-size: .82rem;
  font-weight: 700;
  color: var(--text);
  line-height: 1.2;
}

.vg-export-btn__desc {
  font-size: .7rem;
  color: var(--text-light);
  line-height: 1.3;
}

/* ── Modal premium ───────────────────────────────────── */
.pm-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10,20,30,.55);
  backdrop-filter: blur(4px);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  opacity: 0;
  transition: opacity .22s ease;
}

.pm-overlay--open { opacity: 1; }

.pm-dialog {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 24px;
  width: 100%;
  max-width: 480px;
  box-shadow: 0 32px 80px rgba(0,0,0,.22), 0 0 0 1px rgba(255,255,255,.05);
  transform: translateY(16px) scale(.98);
  transition: transform .25s cubic-bezier(.2,.8,.2,1);
  overflow: hidden;
}

.pm-overlay--open .pm-dialog { transform: translateY(0) scale(1); }

.pm-dialog__header {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 24px 24px 20px;
  border-bottom: 1px solid var(--border);
}

.pm-dialog__icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: linear-gradient(135deg, rgba(0,155,193,.15), rgba(0,179,126,.1));
  display: grid;
  place-items: center;
  color: var(--primary);
  flex-shrink: 0;
}

.pm-dialog__icon i,
.pm-dialog__icon svg { width: 18px; height: 18px; }

.pm-dialog__title {
  margin: 0 0 3px;
  font-size: 1rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -.02em;
}

.pm-dialog__desc {
  margin: 0;
  font-size: .8rem;
  color: var(--text-light);
}

.pm-dialog__close {
  margin-left: auto;
  width: 32px;
  height: 32px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--bg);
  color: var(--text-light);
  display: grid;
  place-items: center;
  cursor: pointer;
  font-family: inherit;
  flex-shrink: 0;
  min-height: unset;
  transition: background .15s, color .15s;
  width: 32px;
}

.pm-dialog__close:hover { background: rgba(230,57,70,.08); color: var(--danger); border-color: rgba(230,57,70,.2); transform: none; box-shadow: none; }
.pm-dialog__close i, .pm-dialog__close svg { width: 15px; height: 15px; }

.pm-dialog__body {
  padding: 22px 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.pm-field { display: flex; flex-direction: column; gap: 6px; }
.pm-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

.pm-label {
  font-size: .76rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: .01em;
}

.pm-input {
  padding: 11px 14px;
  background: var(--bg);
  border: 1.5px solid var(--border);
  border-radius: 12px;
  font-family: inherit;
  font-size: .88rem;
  color: var(--text);
  outline: none;
  transition: border-color .18s, box-shadow .18s, background .18s;
  width: 100%;
  box-sizing: border-box;
  margin: 0;
}

.pm-input:focus {
  border-color: var(--primary);
  background: var(--bg-card);
  box-shadow: 0 0 0 3px rgba(0,155,193,.12);
}

.pm-input::placeholder { color: var(--text-light); opacity: .6; }

/* Segmented control */
.pm-seg {
  display: flex;
  gap: 6px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 4px;
}

.pm-seg__btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 8px 12px;
  border-radius: 9px;
  border: none;
  background: transparent;
  font-family: inherit;
  font-size: .8rem;
  font-weight: 600;
  color: var(--text-light);
  cursor: pointer;
  transition: background .15s, color .15s, box-shadow .15s;
  min-height: unset;
  width: auto;
}

.pm-seg__btn:hover { color: var(--text); background: rgba(0,0,0,.04); transform: none; box-shadow: none; }

.pm-seg__btn.active {
  background: var(--bg-card);
  color: var(--primary);
  box-shadow: 0 1px 6px rgba(0,0,0,.1);
}

.pm-seg__btn i, .pm-seg__btn svg { width: 13px; height: 13px; }

.pm-dialog__footer {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  padding: 16px 24px;
  border-top: 1px solid var(--border);
  background: var(--bg);
}

.pm-btn-cancel {
  padding: 10px 18px;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--bg-card);
  font-family: inherit;
  font-size: .85rem;
  font-weight: 600;
  color: var(--text-light);
  cursor: pointer;
  transition: background .15s, color .15s;
  min-height: unset;
  width: auto;
}

.pm-btn-cancel:hover { color: var(--text); background: var(--bg); transform: none; box-shadow: none; }

.pm-btn-confirm {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 10px 20px;
  border-radius: 10px;
  border: none;
  background: linear-gradient(135deg, var(--primary), #00a693);
  color: #fff;
  font-family: inherit;
  font-size: .85rem;
  font-weight: 700;
  cursor: pointer;
  transition: opacity .15s, transform .12s, box-shadow .15s;
  box-shadow: 0 4px 14px rgba(0,155,193,.3);
  min-height: unset;
  width: auto;
  position: relative;
}

.pm-btn-confirm:hover { opacity: .9; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,155,193,.35); }
.pm-btn-confirm:active { transform: translateY(0); }
.pm-btn-confirm i, .pm-btn-confirm svg { width: 15px; height: 15px; }

.pm-btn-confirm.loading { color: transparent; }
.pm-btn-confirm.loading::after {
  content: '';
  position: absolute;
  left: 50%; top: 50%;
  width: 16px; height: 16px;
  border: 2px solid rgba(255,255,255,.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin .7s linear infinite;
  transform: translate(-50%, -50%);
}

/* ── Responsivo ─────────────────────────────────────── */
@media (max-width: 1200px) {
  .vg-content   { grid-template-columns: 1fr 300px; }
  .vg-hero__kpis { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 1024px) {
  .vg-content   { grid-template-columns: 1fr; }
  .vg-sidebar   { display: grid; grid-template-columns: 1fr 1fr; }
  .vg-command   { grid-template-columns: 1fr; }
}

@media (max-width: 768px) {
  .vg-hero        { flex-direction: column; align-items: flex-start; gap: 20px; }
  .vg-hero__divider { width: 100%; height: 1px; margin: 0; }
  .vg-hero__kpis  { grid-template-columns: repeat(2, 1fr); width: 100%; }
  .vg-modalities  { grid-template-columns: 1fr; }
  .vg-bottom      { grid-template-columns: 1fr; }
  .vg-sidebar     { grid-template-columns: 1fr; }
  .vg-export-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 560px) {
  .vg-hero__kpis   { grid-template-columns: 1fr 1fr; }
  .vg-hero__engagement { flex-direction: column; align-items: flex-start; }
  .vg-mod__stats   { grid-template-columns: repeat(2, 1fr); }
  .vg-podium-cols,
  .vg-radar-cols   { grid-template-columns: 1fr; }
  .vg-export-grid  { grid-template-columns: 1fr; }
  .pm-field-row    { grid-template-columns: 1fr; }
}

/* ── Dark mode ──────────────────────────────────────── */
body[data-theme="dark"] .vg-hero__kpi,
body.dark-mode .vg-hero__kpi,
body[data-theme="dark"] .vg-mod__stat,
body.dark-mode .vg-mod__stat,
body[data-theme="dark"] .vg-fin-cell,
body.dark-mode .vg-fin-cell,
body[data-theme="dark"] .vg-export-btn,
body.dark-mode .vg-export-btn {
  background: rgba(255,255,255,.04);
}

body[data-theme="dark"] .pm-dialog__footer,
body.dark-mode .pm-dialog__footer {
  background: rgba(255,255,255,.03);
}

body[data-theme="dark"] .pm-seg,
body.dark-mode .pm-seg {
  background: rgba(255,255,255,.04);
}

/* =======================================================
   LAYOUT V12 — Topbar fixa + Sidebar vertical colapsável
   Substitui: .topbar, .menu-flutuante, .menu-item, main
======================================================= */

/* ── Variáveis de layout ──────────────────────────────── */
:root {
  --tb-h: 60px;
  --sb-w: 224px;
  --sb-w-collapsed: 64px;
  --sb-bg: #ffffff;
  --sb-bg-dark: #0c1e2e;
  --tb-bg: #07192d;
  --tb-accent: #009bc1;
  --sb-item-active-bg: rgba(0,155,193,.09);
  --sb-item-active-border: #009bc1;
  --sb-item-hover-bg: rgba(0,155,193,.05);
  --sb-text: #4a5568;
  --sb-text-dark: rgba(255,255,255,.6);
  --sb-text-active: #009bc1;
  --sb-border: rgba(0,0,0,.07);
  --sb-border-dark: rgba(255,255,255,.07);
  --sb-radius: 10px;
  --ease-sb: cubic-bezier(.4,0,.2,1);
}

/* ── Reset para o layout antigo ─────────────────────────── */
.topbar, .topbar-slim, .menu-flutuante { display: none !important; }

/* ── Body como grid de layout ───────────────────────────── */
body {
  display: grid !important;
  grid-template-rows: var(--tb-h) 1fr !important;
  grid-template-columns: var(--sb-w) 1fr !important;
  grid-template-areas:
    "topbar topbar"
    "sidebar main" !important;
  min-height: 100dvh !important;
  overflow: hidden !important;
}
body.sidebar-collapsed {
  grid-template-columns: var(--sb-w-collapsed) 1fr !important;
}

/* ── TOPBAR ──────────────────────────────────────────────── */
.app-topbar {
  grid-area: topbar;
  position: sticky;
  top: 0;
  z-index: 1100;
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 0 20px 0 0;
  background: var(--tb-bg);
  border-bottom: 2px solid var(--tb-accent);
  height: var(--tb-h);
  box-shadow: 0 2px 20px rgba(0,0,0,.25);
}

/* Brand / hamburger */
.app-topbar__brand {
  display: flex;
  align-items: center;
  gap: 0;
  width: var(--sb-w);
  min-width: var(--sb-w);
  padding: 0 12px 0 16px;
  flex: 0 0 auto;
  transition: width .25s var(--ease-sb);
}
body.sidebar-collapsed .app-topbar__brand {
  width: var(--sb-w-collapsed);
  min-width: var(--sb-w-collapsed);
}
.app-topbar__hamburger {
  background: none;
  border: none;
  color: rgba(255,255,255,.75);
  cursor: pointer;
  width: 36px;
  height: 36px;
  min-height: unset;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  transition: background .15s, color .15s;
  padding: 0;
}
.app-topbar__hamburger:hover {
  background: rgba(255,255,255,.1);
  color: #fff;
  transform: none;
  box-shadow: none;
}
.app-topbar__logo {
  height: 34px;
  width: auto;
  max-width: 130px;
  object-fit: contain;
  object-position: left center;
  margin-left: 10px;
  opacity: 1;
  pointer-events: auto;
  transition: max-width .25s var(--ease-sb), opacity .2s var(--ease-sb);
  filter: brightness(0) invert(1);
}
body.sidebar-collapsed .app-topbar__logo {
  max-width: 0;
  opacity: 0;
  margin-left: 0;
  pointer-events: none;
  overflow: hidden;
}

/* Search */
.app-topbar__search {
  flex: 1;
  position: relative;
  max-width: 440px;
  display: flex;
  align-items: center;
}
.app-topbar__search-icon {
  position: absolute;
  left: 12px;
  color: rgba(255,255,255,.45);
  pointer-events: none;
  width: 16px;
  height: 16px;
}
.app-topbar__search-input {
  width: 100%;
  height: 38px;
  background: rgba(255,255,255,.08) !important;
  border: 1px solid rgba(255,255,255,.12) !important;
  border-radius: 10px !important;
  color: #fff !important;
  font-size: .875rem;
  padding: 0 56px 0 36px !important;
  font-family: inherit;
  transition: background .2s, border-color .2s, box-shadow .2s !important;
  outline: none;
}
.app-topbar__search-input::placeholder { color: rgba(255,255,255,.38) !important; }
.app-topbar__search-input:focus {
  background: rgba(255,255,255,.13) !important;
  border-color: rgba(0,155,193,.6) !important;
  box-shadow: 0 0 0 3px rgba(0,155,193,.18) !important;
}
.app-topbar__search-hint {
  position: absolute;
  right: 10px;
  font-size: 11px;
  color: rgba(255,255,255,.28);
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 5px;
  padding: 2px 6px;
  font-family: inherit;
  pointer-events: none;
  transition: opacity .2s;
}
.app-topbar__search-input:focus ~ .app-topbar__search-hint { opacity: 0; }

/* Actions */
.app-topbar__actions {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-left: auto;
}
.app-topbar__icon-btn {
  width: 38px;
  height: 38px;
  min-height: unset;
  border-radius: 10px;
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.08);
  color: rgba(255,255,255,.8);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background .15s, color .15s;
  padding: 0;
}
.app-topbar__icon-btn:hover {
  background: rgba(255,255,255,.15);
  color: #fff;
  transform: none;
  box-shadow: none;
}
.app-topbar__icon-btn svg { width: 18px; height: 18px; }

/* User chip */
.app-topbar__user {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 4px 12px 4px 4px;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 40px;
  cursor: default;
}
.app-topbar__avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--tb-accent);
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  text-transform: uppercase;
}
.app-topbar__user-info {
  display: flex;
  flex-direction: column;
  line-height: 1.1;
}
.app-topbar__user-info strong {
  font-size: .8rem;
  color: #fff;
  font-weight: 600;
  white-space: nowrap;
}
#userGroupBadge {
  font-size: .68rem !important;
  font-weight: 700 !important;
  color: rgba(255,255,255,.7) !important;
  background: none !important;
  padding: 0 !important;
  text-transform: uppercase;
  letter-spacing: .04em;
  display: block !important;
}

/* ── SIDEBAR ─────────────────────────────────────────────── */
.app-sidebar {
  grid-area: sidebar;
  position: sticky;
  top: var(--tb-h);
  height: calc(100dvh - var(--tb-h));
  width: var(--sb-w);
  background: var(--sb-bg);
  border-right: 1px solid var(--sb-border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: width .25s var(--ease-sb);
  z-index: 900;
  flex-shrink: 0;
  box-shadow: 2px 0 20px rgba(0,0,0,.04);
}
body.sidebar-collapsed .app-sidebar { width: var(--sb-w-collapsed); }

/* Nav items */
.app-sidebar__nav {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 16px 10px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  scrollbar-width: none;
}
.app-sidebar__nav::-webkit-scrollbar { display: none; }

/* menu-item override — gerado pelo JS */
.app-sidebar__nav .menu-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 12px;
  border-radius: var(--sb-radius);
  color: var(--sb-text);
  font-size: .875rem;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  overflow: hidden;
  border-left: 3px solid transparent;
  transition: background .15s, color .15s, border-color .15s;
  position: relative;
  background: none;
  box-shadow: none;
}
.app-sidebar__nav .menu-item svg {
  width: 18px;
  height: 18px;
  flex: 0 0 18px;
  stroke-width: 1.8;
  transition: color .15s;
}
.app-sidebar__nav .menu-item span {
  transition: opacity .15s var(--ease-sb), width .15s var(--ease-sb);
  opacity: 1;
  overflow: hidden;
}
body.sidebar-collapsed .app-sidebar__nav .menu-item span {
  opacity: 0;
  width: 0;
  pointer-events: none;
}
.app-sidebar__nav .menu-item:hover {
  background: var(--sb-item-hover-bg);
  color: var(--sb-text-active);
}
.app-sidebar__nav .menu-item.active {
  background: var(--sb-item-active-bg);
  color: var(--sb-text-active);
  border-left-color: var(--sb-item-active-border);
  font-weight: 600;
  box-shadow: none;
}
.app-sidebar__nav .menu-item.active svg { color: var(--sb-text-active); }

/* Tooltip no modo colapsado */
body.sidebar-collapsed .app-sidebar__nav .menu-item {
  justify-content: center;
  padding: 12px;
  border-radius: 10px;
  border-left: 3px solid transparent;
}
body.sidebar-collapsed .app-sidebar__nav .menu-item.active {
  border-left-color: var(--sb-item-active-border);
}

/* Footer collapse */
.app-sidebar__footer {
  padding: 10px;
  border-top: 1px solid var(--sb-border);
}
.app-sidebar__collapse {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 9px 12px;
  background: none;
  border: none;
  border-radius: var(--sb-radius);
  color: var(--sb-text);
  font-size: .8rem;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  overflow: hidden;
  min-height: unset;
  transition: background .15s, color .15s;
}
.app-sidebar__collapse:hover {
  background: var(--sb-item-hover-bg);
  color: var(--sb-text-active);
  transform: none;
  box-shadow: none;
}
.app-sidebar__collapse svg { width: 18px; height: 18px; flex: 0 0 18px; }
.app-sidebar__collapse span {
  transition: opacity .15s, width .15s;
  opacity: 1;
}
body.sidebar-collapsed .app-sidebar__collapse span {
  opacity: 0;
  width: 0;
}
body.sidebar-collapsed .app-sidebar__collapse {
  justify-content: center;
  padding: 12px;
}

/* ── MAIN ────────────────────────────────────────────────── */
.app-main {
  grid-area: main;
  overflow-y: auto;
  overflow-x: hidden;
  height: calc(100dvh - var(--tb-h));
  padding: 28px 28px 60px !important;
  max-width: none !important;
  margin: 0 !important;
  box-sizing: border-box;
}

/* ── DARK MODE ───────────────────────────────────────────── */
body[data-theme="dark"] .app-sidebar,
body.dark-mode .app-sidebar {
  background: var(--sb-bg-dark);
  border-right-color: var(--sb-border-dark);
  box-shadow: 2px 0 20px rgba(0,0,0,.25);
}
body[data-theme="dark"] .app-sidebar__nav .menu-item,
body.dark-mode .app-sidebar__nav .menu-item {
  color: var(--sb-text-dark);
}
body[data-theme="dark"] .app-sidebar__nav .menu-item:hover,
body.dark-mode .app-sidebar__nav .menu-item:hover {
  background: rgba(0,155,193,.1);
  color: #56d4f5;
}
body[data-theme="dark"] .app-sidebar__nav .menu-item.active,
body.dark-mode .app-sidebar__nav .menu-item.active {
  background: rgba(0,155,193,.12);
  color: #56d4f5;
  border-left-color: #56d4f5;
}
body[data-theme="dark"] .app-sidebar__footer,
body.dark-mode .app-sidebar__footer {
  border-top-color: var(--sb-border-dark);
}
body[data-theme="dark"] .app-sidebar__collapse,
body.dark-mode .app-sidebar__collapse {
  color: var(--sb-text-dark);
}

/* ── RESPONSIVE ─────────────────────────────────────────── */
@media (max-width: 768px) {
  body {
    grid-template-columns: 0 1fr !important;
  }
  body.sidebar-open {
    grid-template-columns: var(--sb-w) 1fr !important;
  }
  .app-sidebar {
    position: fixed !important;
    left: 0;
    top: var(--tb-h);
    width: var(--sb-w) !important;
    transform: translateX(-100%);
    transition: transform .25s var(--ease-sb) !important;
    z-index: 1050;
    box-shadow: 4px 0 30px rgba(0,0,0,.15);
  }
  body.sidebar-open .app-sidebar {
    transform: translateX(0) !important;
  }
  .app-topbar__brand {
    width: auto !important;
    min-width: unset !important;
  }
  .app-topbar__user-info { display: none; }
  .app-main { padding: 20px 16px 48px !important; }
  .app-sidebar__collapse { display: none; }
}
@media (max-width: 480px) {
  .app-topbar__search { max-width: 160px; }
  .app-topbar__search-hint { display: none; }
}

/* =======================================================
   V13 — Section headers, sidebar divider, role-based UX
======================================================= */

/* ── Section header ─────────────────────────────────── */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  margin-bottom: 20px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap;
}
.section-header__text h2 {
  margin: 0 0 4px;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -.02em;
}
.section-header__text p {
  margin: 0;
  font-size: .875rem;
  color: var(--text-light);
  line-height: 1.5;
}
.section-header__action {
  flex-shrink: 0;
  white-space: nowrap;
}

/* Admin section header — visual diferenciado */
.section-header--admin .section-header__text h2 {
  color: var(--danger);
}
.section-header--admin {
  border-bottom-color: rgba(230,57,70,.15);
  background: rgba(230,57,70,.03);
  border-radius: 12px;
  padding: 16px 18px 16px;
  margin-bottom: 16px;
  border: 1px solid rgba(230,57,70,.1);
}

/* ── Sidebar divider entre comitê e admin ───────────── */
.sidebar-divider {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 16px 12px 6px;
  color: var(--text-light);
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  opacity: .6;
  user-select: none;
}
.sidebar-divider::before {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

/* Item admin na sidebar */
.app-sidebar__nav .menu-item.menu-item--admin {
  color: var(--danger);
  opacity: .8;
}
.app-sidebar__nav .menu-item.menu-item--admin:hover {
  background: rgba(230,57,70,.06);
  color: var(--danger);
  opacity: 1;
}
.app-sidebar__nav .menu-item.menu-item--admin.active {
  background: rgba(230,57,70,.08);
  color: var(--danger);
  border-left-color: var(--danger);
  opacity: 1;
}

/* ── Sub-menu (tabs dentro de seção) — visual unificado */
.sub-menu {
  display: flex !important;
  gap: 4px !important;
  padding: 0 !important;
  margin-bottom: 20px !important;
  background: var(--bg-card) !important;
  border: 1px solid var(--border) !important;
  border-radius: 12px !important;
  padding: 4px !important;
  width: fit-content !important;
  max-width: 100% !important;
  overflow-x: auto !important;
  scrollbar-width: none !important;
  box-shadow: none !important;
  position: static !important;
  bottom: unset !important;
  left: unset !important;
  transform: none !important;
}
.sub-menu::-webkit-scrollbar { display: none !important; }
.sub-tab {
  display: flex !important;
  align-items: center !important;
  gap: 7px !important;
  padding: 8px 16px !important;
  border-radius: 9px !important;
  background: none !important;
  border: none !important;
  color: var(--text-light) !important;
  font-size: .85rem !important;
  font-weight: 500 !important;
  cursor: pointer !important;
  white-space: nowrap !important;
  transition: background .15s, color .15s !important;
  box-shadow: none !important;
  min-height: unset !important;
  width: auto !important;
}
.sub-tab svg { width: 15px !important; height: 15px !important; }
.sub-tab:hover {
  background: rgba(0,155,193,.06) !important;
  color: var(--primary) !important;
  transform: none !important;
}
.sub-tab.active {
  background: var(--primary) !important;
  color: #fff !important;
  font-weight: 600 !important;
  box-shadow: 0 2px 8px rgba(0,155,193,.25) !important;
}
/* admin-only sub-tab: manter escondido quando não for admin */
.sub-tab.admin-only-element { display: none !important; }

/* Tertiary menu (3° nível) */
.tertiary-menu {
  display: flex !important;
  gap: 4px !important;
  padding: 4px !important;
  background: rgba(0,0,0,.03) !important;
  border-radius: 10px !important;
  margin-bottom: 16px !important;
  width: fit-content !important;
  border: 1px solid var(--border) !important;
  overflow-x: auto !important;
  scrollbar-width: none !important;
}
.tertiary-menu::-webkit-scrollbar { display: none !important; }
.t-tab {
  padding: 6px 14px !important;
  border-radius: 7px !important;
  background: none !important;
  border: none !important;
  color: var(--text-light) !important;
  font-size: .82rem !important;
  font-weight: 500 !important;
  cursor: pointer !important;
  white-space: nowrap !important;
  transition: background .15s, color .15s !important;
  min-height: unset !important;
}
.t-tab:hover {
  background: rgba(0,155,193,.06) !important;
  color: var(--primary) !important;
  transform: none !important;
}
.t-tab.active {
  background: var(--primary) !important;
  color: #fff !important;
  font-weight: 600 !important;
}

/* ── Dark mode ──────────────────────────────────────── */
body[data-theme="dark"] .sub-menu,
body.dark-mode .sub-menu {
  background: rgba(255,255,255,.04) !important;
  border-color: rgba(255,255,255,.07) !important;
}
body[data-theme="dark"] .tertiary-menu,
body.dark-mode .tertiary-menu {
  background: rgba(255,255,255,.03) !important;
  border-color: rgba(255,255,255,.07) !important;
}
body[data-theme="dark"] .section-header,
body.dark-mode .section-header {
  border-bottom-color: rgba(255,255,255,.07);
}
body[data-theme="dark"] .sidebar-divider,
body.dark-mode .sidebar-divider {
  color: rgba(255,255,255,.35);
}
body[data-theme="dark"] .sidebar-divider::before,
body.dark-mode .sidebar-divider::before {
  background: rgba(255,255,255,.08);
}
